---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { VERIFIED_MODELS } from '../data/verified-models';

const title = 'Best Anthropic Models (2026) | Claude Opus 4.6, Sonnet 4.6';
const description = 'Best Anthropic Claude models in 2026 for reasoning, writing, and safety-first workflows. Compare Claude Opus 4.6, Sonnet 4.6, and their pricing.';

const anthropicModels = VERIFIED_MODELS.filter((m) => m.provider === 'Anthropic');
---
<html lang="en"><head><BaseHead title={title} description={description} type="website" /></head><body><Header /><main class="page"><section class="hero"><div class="container"><p class="eyebrow">Provider guide</p><h1>Best Anthropic Models in 2026</h1><p class="subtitle">Anthropic's Claude lineup is still the reasoning and safety king. Opus 4.6 for the hardest tasks. Sonnet 4.6 for production workloads.</p><div class="hero-actions"><a href="/compare" class="btn btn-primary">Compare all models</a><a href="/best-ai-model-for-agents" class="btn btn-secondary">Best for agents</a></div></div></section><section class="container section"><div class="table-wrap"><table><thead><tr><th>Model</th><th>Best for</th><th>Input $/M</th><th>Context</th><th>Coding</th><th>Reasoning</th></tr></thead><tbody>{anthropicModels.map((model) => (<tr><td><strong>{model.name}</strong></td><td>{model.bestFor[0]}</td><td>${model.pricing.input}</td><td>{model.contextWindow}</td><td>{model.scores.coding}</td><td>{model.scores.reasoning}</td></tr>))}</tbody></table></div></section><section class="container section decision-box"><h2>Fast picks</h2><ul><li><strong>Claude Opus 4.6</strong> for complex reasoning, long-form analysis, and critical decisions</li><li><strong>Claude Sonnet 4.6</strong> for balanced production workloads and cost-efficiency</li></ul><div class="link-row"><a href="/best-ai-model-for-coding">Best coding models →</a><a href="/cheapest-ai-models">Cheapest models →</a><a href="/best-long-context-models">Long-context picks →</a></div></section></main><Footer /></body></html><style>.page{padding-bottom:4rem}.container{max-width:1100px;margin:0 auto;padding:0 1.5rem}.hero{padding:4rem 0 3rem;background:var(--gradient-hero)}.eyebrow{color:var(--accent-light);font-size:.8rem;text-transform:uppercase;letter-spacing:.08em;font-weight:700}h1{font-size:clamp(2.2rem,5vw,3.5rem);margin:.5rem 0 1rem}.subtitle{color:var(--text-secondary);max-width:760px;font-size:1.05rem}.hero-actions,.link-row{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.25rem}.btn{display:inline-flex;padding:.8rem 1.1rem;border-radius:12px;text-decoration:none;font-weight:700}.btn-primary{background:var(--gradient-primary);color:white}.btn-secondary{background:var(--bg-tertiary);color:var(--text-primary);border:1px solid var(--border-primary)}.section{padding-top:2rem}.table-wrap{overflow-x:auto;background:var(--bg-card);border:1px solid var(--border-primary);border-radius:18px}table{width:100%;border-collapse:collapse}th,td{padding:.9rem 1rem;border-bottom:1px solid var(--border-secondary);text-align:left}th{color:var(--text-secondary);font-size:.85rem}.decision-box{background:var(--bg-card);border:1px solid var(--border-primary);border-radius:18px;padding:1.25rem}.decision-box h2{font-size:1.1rem;margin-bottom:.5rem}.decision-box ul{margin:1rem 0;padding-left:1.2rem;color:var(--text-secondary)}.decision-box a{color:var(--accent-light);font-weight:700}</style>