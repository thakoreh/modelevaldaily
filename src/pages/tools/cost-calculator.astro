---
import Layout from '../../layouts/BlogPost.astro';
import { allModels, calculateMonthlyCost, type ModelPricing } from '../../data/pricing';

const title = 'AI Model Cost Calculator — Compare Monthly Pricing';
const description = 'Calculate and compare monthly API costs for GPT-5.4, Claude Opus 4.7, Gemini 3.5, and more. Verified pricing data updated March 2026.';
const pubDate = new Date('2026-03-09');
const noindex = false;

// Pre-calculate example costs
const exampleUsage = [
  { label: 'Light (10K input / 5K output per day)', input: 10000, output: 5000 },
  { label: 'Medium (100K input / 50K output per day)', input: 100000, output: 50000 },
  { label: 'Heavy (1M input / 500K output per day)', input: 1000000, output: 500000 },
];

const exampleCosts = exampleUsage.map(usage => ({
  label: usage.label,
  costs: allModels.map(model => ({
    model: model.model,
    provider: model.provider,
    cost: calculateMonthlyCost(usage.input, usage.output, model)
  }))
}));
---

<Layout title={title} description={description} pubDate={pubDate} noindex={noindex}>
  <article class="calculator-page">
    <header>
      <h1>AI Model Cost Calculator</h1>
      <p class="subtitle">
        Compare monthly API costs across all major LLM providers. 
        Pricing verified <strong>March 9, 2026</strong>.
      </p>
    </header>

    <!-- Interactive Calculator -->
    <section class="calculator-section">
      <h2>Calculate Your Monthly Cost</h2>
      
      <div class="calculator-form">
        <div class="input-group">
          <label for="inputTokens">Input tokens per day:</label>
          <input type="number" id="inputTokens" value="100000" min="0" step="1000" />
        </div>
        
        <div class="input-group">
          <label for="outputTokens">Output tokens per day:</label>
          <input type="number" id="outputTokens" value="50000" min="0" step="1000" />
        </div>
        
        <button id="calculateBtn">Calculate Costs</button>
      </div>

      <div id="results" class="results-table"></div>
    </section>

    <!-- Pre-calculated Examples -->
    <section class="examples-section">
      <h2>Example Monthly Costs</h2>
      
      {exampleCosts.map(example => (
        <div class="example-block">
          <h3>{example.label}</h3>
          <table>
            <thead>
              <tr>
                <th>Provider</th>
                <th>Model</th>
                <th>Monthly Cost</th>
              </tr>
            </thead>
            <tbody>
              {example.costs.sort((a, b) => a.cost - b.cost).slice(0, 10).map(item => (
                <tr>
                  <td>{item.provider}</td>
                  <td class="model-name">{item.model}</td>
                  <td class="cost">${item.cost.toFixed(2)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </section>

    <!-- Pricing Data -->
    <section class="pricing-data-section">
      <h2>Full Pricing Data</h2>
      <p class="disclaimer">
        All prices per 1M tokens. Data verified on March 9, 2026 from official sources.
      </p>
      
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Provider</th>
              <th>Model</th>
              <th>Input ($/1M)</th>
              <th>Output ($/1M)</th>
              <th>Context</th>
              <th>Source</th>
            </tr>
          </thead>
          <tbody>
            {allModels.map(model => (
              <tr>
                <td>{model.provider}</td>
                <td class="model-name">{model.model}</td>
                <td class="price">${model.inputCost.toFixed(2)}</td>
                <td class="price">${model.outputCost.toFixed(2)}</td>
                <td class="context">{(model.contextWindow / 1000).toFixed(0)}K</td>
                <td class="source-link">
                  <a href={model.sourceUrl} target="_blank" rel="noopener">Official</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Methodology -->
    <section class="methodology-section">
      <h2>Methodology</h2>
      <ul>
        <li><strong>Tokens per word:</strong> ~1.3 tokens per word (English)</li>
        <li><strong>Days per month:</strong> 30</li>
        <li><strong>Pricing source:</strong> Official provider pricing pages</li>
        <li><strong>Last verified:</strong> March 9, 2026</li>
        <li><strong>Excludes:</strong> Prompt caching, batch discounts, volume pricing</li>
      </ul>
      <p class="note">
        Actual costs may vary based on prompt caching, tiered pricing, and volume discounts.
        Always verify with official sources before budgeting.
      </p>
    </section>

    <!-- Sources -->
    <section class="sources-section">
      <h2>Official Pricing Sources</h2>
      <ul>
        <li><a href="https://openai.com/api/pricing/" target="_blank" rel="noopener">OpenAI Pricing</a></li>
        <li><a href="https://platform.claude.com/docs/en/about-claude/pricing" target="_blank" rel="noopener">Anthropic Claude Pricing</a></li>
        <li><a href="https://ai.google.dev/gemini-api/docs/pricing" target="_blank" rel="noopener">Google Gemini Pricing</a></li>
        <li><a href="https://open.bigmodel.cn/pricing" target="_blank" rel="noopener">Zhipu GLM Pricing</a></li>
      </ul>
    </section>

    <footer>
      <p>
        <strong>Data provenance:</strong> All pricing data sourced from official provider pages.
        Last verified March 9, 2026. This page is updated weekly.
      </p>
    </footer>
  </article>
</Layout>

<script>
  import { allModels, calculateMonthlyCost } from '../../data/pricing';

  const inputTokensInput = document.getElementById('inputTokens') as HTMLInputElement;
  const outputTokensInput = document.getElementById('outputTokens') as HTMLInputElement;
  const calculateBtn = document.getElementById('calculateBtn') as HTMLButtonElement;
  const resultsDiv = document.getElementById('results') as HTMLDivElement;

  function formatCost(cost: number): string {
    if (cost < 1) return `$${cost.toFixed(3)}`;
    if (cost < 10) return `$${cost.toFixed(2)}`;
    return `$${cost.toFixed(0)}`;
  }

  function calculate() {
    const inputTokens = parseInt(inputTokensInput.value) || 0;
    const outputTokens = parseInt(outputTokensInput.value) || 0;

    const costs = allModels
      .map(model => ({
        ...model,
        monthlyCost: calculateMonthlyCost(inputTokens, outputTokens, model)
      }))
      .sort((a, b) => a.monthlyCost - b.monthlyCost);

    resultsDiv.innerHTML = `
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Provider</th>
            <th>Model</th>
            <th>Monthly Cost</th>
            <th>Per Day</th>
          </tr>
        </thead>
        <tbody>
          ${costs.map((model, index) => `
            <tr>
              <td class="rank">#${index + 1}</td>
              <td>${model.provider}</td>
              <td class="model-name">${model.model}</td>
              <td class="cost">${formatCost(model.monthlyCost)}</td>
              <td class="daily">${formatCost(model.monthlyCost / 30)}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  calculateBtn.addEventListener('click', calculate);
  calculate(); // Run once on load
</script>

<style>
  .calculator-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }

  header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
  }

  section {
    margin: 3rem 0;
  }

  h2 {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  h3 {
    font-size: 1.25rem;
    margin: 1.5rem 0 1rem;
  }

  .calculator-form {
    display: flex;
    gap: 1rem;
    align-items: flex-end;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-group label {
    font-weight: 600;
    font-size: 0.875rem;
  }

  .input-group input {
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font-size: 1rem;
    width: 200px;
  }

  button {
    padding: 0.75rem 2rem;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-weight: 600;
    cursor: pointer;
    font-size: 1rem;
  }

  button:hover {
    background: var(--accent-hover);
  }

  .table-wrapper {
    overflow-x: auto;
    margin: 1rem 0;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  th, td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  th {
    background: var(--bg-secondary);
    font-weight: 600;
  }

  .rank {
    font-weight: 700;
    color: var(--text-secondary);
  }

  .model-name {
    font-weight: 600;
  }

  .cost, .price {
    font-weight: 700;
    font-family: monospace;
    color: var(--accent);
  }

  .daily {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .context {
    font-family: monospace;
  }

  .source-link a {
    color: var(--text-tertiary);
    font-size: 0.75rem;
    text-decoration: underline;
  }

  .example-block {
    margin: 2rem 0;
  }

  .disclaimer {
    background: var(--bg-secondary);
    padding: 1rem;
    border-radius: 0.5rem;
    border-left: 3px solid var(--warning);
    margin: 1rem 0;
    font-size: 0.875rem;
  }

  .note {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: 1rem;
  }

  .methodology-section ul,
  .sources-section ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 1rem 0;
  }

  li {
    margin: 0.5rem 0;
  }

  .sources-section a {
    color: var(--accent);
  }

  footer {
    background: var(--bg-secondary);
    padding: 1.5rem;
    border-radius: 0.5rem;
    margin-top: 3rem;
    font-size: 0.875rem;
  }

  .results-table {
    margin-top: 2rem;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 1.75rem;
    }

    .calculator-form {
      flex-direction: column;
      align-items: stretch;
    }

    .input-group input {
      width: 100%;
    }

    table {
      font-size: 0.75rem;
    }

    th, td {
      padding: 0.5rem;
    }
  }
</style>
