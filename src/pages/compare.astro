---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { MODEL_DATA_VERIFIED_ON, VERIFIED_MODELS } from '../data/verified-models';

const slugify = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const models = VERIFIED_MODELS.map((model) => ({ ...model, slug: slugify(model.name) }));
const requested = (Astro.url.searchParams.get('models') ?? '').split(',').filter(Boolean);
const validRequested = requested.filter((slug, index) => models.some((model) => model.slug === slug) && requested.indexOf(slug) === index).slice(0, 3);
const selectedSlugs = validRequested.length >= 2 ? validRequested : models.slice(0, 2).map((model) => model.slug);
const selected = selectedSlugs.map((slug) => models.find((model) => model.slug === slug)!).filter(Boolean);
const fit = (model: (typeof models)[number]) => model.scores.coding * 0.4 + model.scores.reasoning * 0.35 + model.scores.toolUse * 0.25;
const contextNumber = (value: string) => Number.parseFloat(value) * (value.toUpperCase().includes('M') ? 1_000_000 : 1_000);
const maxOf = (getter: (model: (typeof selected)[number]) => number) => Math.max(...selected.map(getter));
const minOf = (getter: (model: (typeof selected)[number]) => number) => Math.min(...selected.map(getter));
const metricRows = [
	{ label: 'Editorial fit', note: '40% coding · 35% reasoning · 25% tool use', value: fit, format: (value: number) => value.toFixed(1), best: 'max' },
	{ label: 'Coding', note: 'Normalized editorial dimension', value: (model: (typeof selected)[number]) => model.scores.coding, format: (value: number) => value.toFixed(1), best: 'max' },
	{ label: 'Reasoning', note: 'Normalized editorial dimension', value: (model: (typeof selected)[number]) => model.scores.reasoning, format: (value: number) => value.toFixed(1), best: 'max' },
	{ label: 'Tool use', note: 'Normalized editorial dimension', value: (model: (typeof selected)[number]) => model.scores.toolUse, format: (value: number) => value.toFixed(1), best: 'max' },
	{ label: 'Context window', note: 'Provider specification', value: (model: (typeof selected)[number]) => contextNumber(model.contextWindow), display: (model: (typeof selected)[number]) => model.contextWindow, best: 'max' },
	{ label: 'Input price', note: 'USD per 1M tokens', value: (model: (typeof selected)[number]) => model.pricing.input, format: (value: number) => `$${value}`, best: 'min' },
	{ label: 'Output price', note: 'USD per 1M tokens', value: (model: (typeof selected)[number]) => model.pricing.output, format: (value: number) => `$${value}`, best: 'min' },
];
---
<!doctype html>
<html lang="en">
	<head><BaseHead title={`${selected.map((model) => model.name).join(' vs ')} | ${SITE_TITLE}`} description={`Compare ${selected.map((model) => model.name).join(', ')} across editorial fit, coding, reasoning, tool use, context, pricing, and evidence.`} /></head>
	<body>
		<Header />
		<main class="compare-page">
			<section class="page-intro container">
				<span class="eyebrow">Side-by-side decision workspace</span>
				<h1>Compare models without flattening the tradeoffs.</h1>
				<p>Choose two or three models. We’ll keep capability, price, context, caveats, and evidence in the same view.</p>
			</section>

			<section class="selector-band">
				<form class="container selector-form" id="comparison-form">
					{[0, 1, 2].map((index) => <label><span>Model {index + 1}{index === 2 ? ' (optional)' : ''}</span><select class="model-select" data-index={index}><option value="">{index === 2 ? 'No third model' : 'Select a model'}</option>{models.map((model) => <option value={model.slug} selected={selectedSlugs[index] === model.slug}>{model.name} — {model.provider}</option>)}</select></label>)}
					<button class="btn btn-primary" type="submit">Update comparison →</button>
				</form>
			</section>

			<section class="comparison container" aria-labelledby="comparison-heading">
				<div class="comparison-head"><div><span class="eyebrow">Decision summary</span><h2 id="comparison-heading"><span id="comparison-title">{selected.map((model) => model.name).join(' vs ')}</span></h2></div><div class="share-note"><span class="badge badge-success">Reviewed {MODEL_DATA_VERIFIED_ON}</span><button id="copy-link" type="button">Copy comparison link</button></div></div>

				<div id="model-summaries" class:list={['model-summaries', `columns-${selected.length}`]}>
					{selected.map((model) => <article class="model-summary" style={`--model-color:${model.color}`}><div class="model-title"><span class="model-swatch"></span><div><span class="meta">{model.provider}</span><h3>{model.name}</h3></div></div><div class="headline-score"><strong class="mono">{fit(model).toFixed(1)}</strong><span>editorial fit</span></div><p>{model.strengths.slice(0, 2).join('. ')}.</p><div class="tag-list">{model.bestFor.slice(0, 3).map((item) => <span>{item}</span>)}</div>{model.pricing.notes && <div class="caveat"><strong>Pricing caveat</strong><p>{model.pricing.notes}</p></div>}</article>)}
				</div>

				<div class="matrix-wrap">
					<table class="comparison-matrix">
						<thead><tr id="matrix-head"><th>Decision factor</th>{selected.map((model) => <th>{model.name}</th>)}</tr></thead>
						<tbody id="matrix-body">
							{metricRows.map((metric) => {
								const target = metric.best === 'min' ? minOf(metric.value) : maxOf(metric.value);
								return <tr><td><strong>{metric.label}</strong><span>{metric.note}</span></td>{selected.map((model) => { const numeric = metric.value(model); return <td><strong class="mono">{'display' in metric && metric.display ? metric.display(model) : metric.format?.(numeric)}</strong>{numeric === target && <span class="best-label">Best in this set</span>}</td>; })}</tr>;
							})}
							<tr><td><strong>Best fit</strong><span>From the catalog record</span></td>{selected.map((model) => <td><ul>{model.bestFor.slice(0, 3).map((item) => <li>{item}</li>)}</ul></td>)}</tr>
							<tr><td><strong>Source trail</strong><span>Open before choosing</span></td>{selected.map((model) => <td><div class="source-list">{model.sources.map((source) => <a href={source.url} target="_blank" rel="noopener noreferrer">{source.label} ↗</a>)}</div></td>)}</tr>
						</tbody>
					</table>
				</div>
			</section>

			<section class="decision-guidance container">
				<div><span class="eyebrow">How to decide</span><h2>Choose the constraint that can’t move.</h2></div>
				<div class="guidance-list"><div><span class="mono">01</span><p><strong>Quality floor:</strong> eliminate any model that cannot reliably complete the task, regardless of price.</p></div><div><span class="mono">02</span><p><strong>Operating constraint:</strong> compare real context, throughput, privacy, and deployment requirements.</p></div><div><span class="mono">03</span><p><strong>Total cost:</strong> calculate the full prompt/output mix and account for retries, caching, and routing.</p></div></div>
			</section>
		</main>
		<Footer />
		<script id="comparison-data" type="application/json" set:html={JSON.stringify(models)}></script>
		<script is:inline>
			(() => {
				const form = document.getElementById('comparison-form');
				const selects = [...document.querySelectorAll('.model-select')];
				const allModels = JSON.parse(document.getElementById('comparison-data')?.textContent || '[]');
				const fromUrl = (new URLSearchParams(window.location.search).get('models') || '').split(',').filter((slug, index, list) => slug && list.indexOf(slug) === index).map((slug) => allModels.find((model) => model.slug === slug)).filter(Boolean).slice(0, 3);
				const fit = (model) => model.scores.coding * 0.4 + model.scores.reasoning * 0.35 + model.scores.toolUse * 0.25;
				const contextNumber = (value) => Number.parseFloat(value) * (value.toUpperCase().includes('M') ? 1000000 : 1000);
				const el = (tag, className, text) => { const node = document.createElement(tag); if (className) node.className = className; if (text !== undefined) node.textContent = text; return node; };
				const render = (chosen) => {
					if (chosen.length < 2) return;
					selects.forEach((select, index) => { select.value = chosen[index]?.slug || ''; });
					document.getElementById('comparison-title').textContent = chosen.map((model) => model.name).join(' vs ');
					const summaries = document.getElementById('model-summaries');
					summaries.className = `model-summaries columns-${chosen.length}`;
					summaries.replaceChildren(...chosen.map((model) => {
						const article = el('article', 'model-summary'); article.style.setProperty('--model-color', model.color);
						const title = el('div', 'model-title'); title.append(el('span', 'model-swatch')); const titleCopy = el('div'); titleCopy.append(el('span', 'meta', model.provider), el('h3', '', model.name)); title.append(titleCopy);
						const score = el('div', 'headline-score'); score.append(el('strong', 'mono', fit(model).toFixed(1)), el('span', '', 'editorial fit'));
						const description = el('p', '', `${model.strengths.slice(0, 2).join('. ')}.`);
						const tags = el('div', 'tag-list'); model.bestFor.slice(0, 3).forEach((item) => tags.append(el('span', '', item)));
						article.append(title, score, description, tags);
						if (model.pricing.notes) { const caveat = el('div', 'caveat'); caveat.append(el('strong', '', 'Pricing caveat'), el('p', '', model.pricing.notes)); article.append(caveat); }
						return article;
					}));
					const head = document.getElementById('matrix-head'); head.replaceChildren(el('th', '', 'Decision factor'), ...chosen.map((model) => el('th', '', model.name)));
					const metrics = [
						['Editorial fit','40% coding · 35% reasoning · 25% tool use',fit,(model,value)=>value.toFixed(1),'max'],
						['Coding','Normalized editorial dimension',(model)=>model.scores.coding,(model,value)=>value.toFixed(1),'max'],
						['Reasoning','Normalized editorial dimension',(model)=>model.scores.reasoning,(model,value)=>value.toFixed(1),'max'],
						['Tool use','Normalized editorial dimension',(model)=>model.scores.toolUse,(model,value)=>value.toFixed(1),'max'],
						['Context window','Provider specification',(model)=>contextNumber(model.contextWindow),(model)=>model.contextWindow,'max'],
						['Input price','USD per 1M tokens',(model)=>model.pricing.input,(model,value)=>`$${value}`,'min'],
						['Output price','USD per 1M tokens',(model)=>model.pricing.output,(model,value)=>`$${value}`,'min'],
					];
					const body = document.getElementById('matrix-body');
					const rows = metrics.map(([label,note,getter,format,best]) => {
						const values = chosen.map(getter); const target = best === 'min' ? Math.min(...values) : Math.max(...values); const row = el('tr'); const labelCell = el('td'); labelCell.append(el('strong','',label), el('span','',note)); row.append(labelCell);
						chosen.forEach((model,index) => { const cell=el('td'); cell.append(el('strong','mono',format(model,values[index]))); if(values[index]===target) cell.append(el('span','best-label','Best in this set')); row.append(cell); }); return row;
					});
					const bestRow = el('tr'); const bestLabel = el('td'); bestLabel.append(el('strong','','Best fit'),el('span','','From the catalog record')); bestRow.append(bestLabel); chosen.forEach((model)=>{const cell=el('td');const list=el('ul');model.bestFor.slice(0,3).forEach((item)=>list.append(el('li','',item)));cell.append(list);bestRow.append(cell);}); rows.push(bestRow);
					const sourceRow = el('tr'); const sourceLabel=el('td'); sourceLabel.append(el('strong','','Source trail'),el('span','','Open before choosing'));sourceRow.append(sourceLabel);chosen.forEach((model)=>{const cell=el('td');const list=el('div','source-list');model.sources.forEach((source)=>{const link=el('a','',`${source.label} ↗`);link.href=source.url;link.target='_blank';link.rel='noopener noreferrer';list.append(link);});cell.append(list);sourceRow.append(cell);});rows.push(sourceRow);
					body.replaceChildren(...rows);
				};
				if (fromUrl.length >= 2) render(fromUrl);
				form?.addEventListener('submit', (event) => {
					event.preventDefault();
					const values = selects.map((select) => select.value).filter((value, index, all) => value && all.indexOf(value) === index).slice(0, 3);
					if (values.length < 2) { selects[1]?.focus(); return; }
					window.location.href = `/compare/?models=${values.join(',')}`;
				});
				document.getElementById('copy-link')?.addEventListener('click', async (event) => {
					try { await navigator.clipboard.writeText(window.location.href); event.currentTarget.textContent = 'Link copied'; } catch { event.currentTarget.textContent = 'Copy failed'; }
				});
			})();
		</script>
	</body>
</html>

<style>
	.compare-page { width: 100%; max-width: none; padding: 0; }
	.page-intro { padding-block: 5.5rem 4rem; }
	.page-intro h1 { max-width: 1020px; font-size: clamp(3.5rem, 7vw, 7rem); line-height: 0.93; }
	.page-intro p { max-width: 680px; margin-top: 1.5rem; font-size: 1.12rem; }
	.selector-band { border-block: 1px solid var(--line); background: var(--surface); }
	.selector-form { padding-block: 1.2rem; display: grid; grid-template-columns: repeat(3, 1fr) auto; gap: 0.75rem; align-items: end; }
	.selector-form label { display: flex; flex-direction: column; gap: 0.3rem; color: var(--ink-faint); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
	.selector-form select { min-height: 44px; padding: 0.55rem 0.65rem; border: 1px solid var(--line); border-radius: var(--radius-md); background: var(--canvas); color: var(--ink); font-size: 0.86rem; text-transform: none; }
	.comparison { padding-block: 4.5rem 6rem; }
	.comparison-head { margin-bottom: 2rem; display: flex; align-items: end; justify-content: space-between; gap: 2rem; }
	.share-note { display: flex; align-items: center; gap: 0.65rem; }
	#copy-link { min-height: 36px; padding: 0.4rem 0.65rem; border: 1px solid var(--line); border-radius: var(--radius-md); background: var(--surface); color: var(--ink-muted); cursor: pointer; font-size: 0.75rem; }
	.model-summaries { display: grid; gap: 1px; padding: 1px; border-radius: var(--radius-lg); background: var(--line); overflow: hidden; }
	.columns-2 { grid-template-columns: repeat(2, 1fr); }
	.columns-3 { grid-template-columns: repeat(3, 1fr); }
	.model-summary { min-width: 0; padding: 1.5rem; background: var(--surface); }
	.model-title { display: flex; align-items: center; gap: 0.7rem; }
	.model-swatch { width: 12px; height: 36px; border-radius: 99px; background: var(--model-color); }
	.model-title h3 { margin: 0; font-size: 1.2rem; }
	.headline-score { margin: 2rem 0 1rem; display: flex; align-items: baseline; gap: 0.65rem; }
	.headline-score strong { color: var(--blue); font-size: 2.6rem; }
	.headline-score span { color: var(--ink-faint); font-size: 0.75rem; }
	.model-summary > p { min-height: 3em; font-size: 0.86rem; }
	.tag-list { display: flex; flex-wrap: wrap; gap: 0.35rem; }
	.tag-list span { padding: 0.25rem 0.5rem; border: 1px solid var(--line); border-radius: 99px; color: var(--ink-muted); font-size: 0.7rem; }
	.caveat { margin-top: 1rem; padding: 0.8rem; border-left: 3px solid var(--amber); background: var(--amber-soft); }
	.caveat strong { color: var(--amber); font-size: 0.72rem; text-transform: uppercase; }
	.caveat p { margin: 0.2rem 0 0; font-size: 0.72rem; }
	.matrix-wrap { margin-top: 2rem; overflow-x: auto; border: 1px solid var(--line); }
	.comparison-matrix { min-width: 760px; table-layout: fixed; }
	.comparison-matrix th:first-child, .comparison-matrix td:first-child { width: 25%; }
	.comparison-matrix td strong, .comparison-matrix td span { display: block; }
	.comparison-matrix td > span, .comparison-matrix td:first-child span { margin-top: 0.2rem; color: var(--ink-faint); font-size: 0.7rem; }
	.best-label { width: fit-content; margin-top: 0.35rem !important; padding: 0.17rem 0.4rem; border-radius: 99px; background: var(--green-soft); color: var(--green) !important; font-weight: 680; }
	.comparison-matrix ul { margin: 0; padding-left: 1rem; font-size: 0.8rem; }
	.source-list { display: flex; flex-direction: column; gap: 0.25rem; }
	.source-list a { font-size: 0.76rem; text-decoration: none; }
	.decision-guidance { padding-block: 5rem; border-top: 1px solid var(--line); display: grid; grid-template-columns: 0.7fr 1.3fr; gap: 5rem; }
	.guidance-list { border-top: 1px solid var(--line-strong); }
	.guidance-list div { display: grid; grid-template-columns: 42px 1fr; gap: 1rem; padding: 1.2rem 0; border-bottom: 1px solid var(--line); }
	.guidance-list span { color: var(--ink-faint); font-size: 0.72rem; }
	.guidance-list p { margin: 0; }
	@media (max-width: 850px) { .selector-form { grid-template-columns: 1fr 1fr; } .selector-form label:nth-child(3) { grid-column: 1 / -1; } .model-summaries { grid-template-columns: 1fr; } .decision-guidance { grid-template-columns: 1fr; gap: 2rem; } }
	@media (max-width: 600px) { .page-intro { padding-block: 4rem 3rem; } .page-intro h1 { font-size: clamp(3.1rem, 15vw, 4.6rem); } .selector-form { grid-template-columns: 1fr; } .selector-form label:nth-child(3) { grid-column: auto; } .comparison { padding-block: 3rem; } .comparison-head { align-items: flex-start; flex-direction: column; } .share-note { flex-wrap: wrap; } }
</style>
