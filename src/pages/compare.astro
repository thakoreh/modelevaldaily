---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { MODEL_DATA_VERIFIED_ON, VERIFIED_MODELS } from '../data/verified-models';

const models = VERIFIED_MODELS;

const useCases = [
	{
		title: 'Best for Coding',
		emoji: '&#128187;',
		pick: 'GPT-5.2',
		reason: 'Top coding performance with excellent agentic capabilities and tool integration.',
		alternative: 'Claude Opus 4.6 for code review quality',
	},
	{
		title: 'Best on a Budget',
		emoji: '&#128176;',
		pick: 'DeepSeek-R1',
		reason: 'Very strong reasoning with one of the lowest published API prices in this set.',
		alternative: 'Gemini 2.5 Flash-Lite for high-volume simple tasks',
	},
	{
		title: 'Best for Long Context',
		emoji: '&#128218;',
		pick: 'Llama 4 Scout',
		reason: 'Up to 10M context window - the largest available. Ideal for massive document processing.',
		alternative: 'Gemini 2.5 Pro for 1M context with better reasoning',
	},
	{
		title: 'Best for Reasoning',
		emoji: '&#129504;',
		pick: 'Claude Opus 4.6 (Adaptive)',
		reason: 'Highest intelligence model with excellent reasoning depth and instruction fidelity.',
		alternative: 'Claude Opus 4.1 for consistent long-context behavior',
	},
	{
		title: 'Best All-Rounder',
		emoji: '&#127942;',
		pick: 'GPT-5.2',
		reason: 'Balanced quality across coding, reasoning, and tool-use with strong agentic capabilities.',
		alternative: 'Gemini 3 Pro for multimodal understanding',
	},
	{
		title: 'Best for Tool-Use',
		emoji: '&#128295;',
		pick: 'GPT-5.2',
		reason: 'Reliable multi-step API and tooling behavior in operator-style tasks.',
		alternative: 'Claude Sonnet 4 for balanced tool use at lower cost',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`AI Model Comparison & Pricing (2026) | ${SITE_TITLE}`}
			description="Compare fact-checked AI models side-by-side. Pricing references are verified against official provider docs as of February 16, 2026."
		/>
		<style>
			main {
				width: 100%;
				max-width: 100%;
				padding: 0;
			}

			.container {
				max-width: var(--container-xl);
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			.page-hero {
				position: relative;
				padding: var(--space-3xl) 0 var(--space-2xl);
				overflow: hidden;
			}

			.page-hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background: var(--gradient-hero);
				pointer-events: none;
			}

			.hero-inner {
				position: relative;
				max-width: var(--container-xl);
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			.hero-text h1 {
				font-size: clamp(2rem, 3.5vw, 2.75rem);
				margin-bottom: var(--space-sm);
			}

			.hero-text > p {
				color: var(--text-secondary);
				font-size: var(--font-lg);
				margin-bottom: var(--space-lg);
				max-width: 600px;
			}

			.hero-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
			}

			.hero-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				font-size: var(--font-sm);
				color: var(--text-tertiary);
				padding: 0.35rem 0.75rem;
				background: var(--bg-tertiary);
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-full);
			}

			.hero-badge .count {
				font-weight: 700;
				color: var(--accent-light);
			}

			.section {
				max-width: var(--container-xl);
				margin: 0 auto;
				padding: var(--space-2xl) 1.5rem;
			}

			.section-header {
				margin-bottom: var(--space-lg);
			}

			.section-header h2 {
				margin-bottom: 0.35rem;
			}

			.section-header p {
				color: var(--text-tertiary);
				font-size: var(--font-base);
			}

			.compare-table-wrapper {
				overflow-x: auto;
				border-radius: var(--radius-xl);
				border: 1px solid var(--border-primary);
				background: var(--bg-card);
			}

			.compare-table {
				width: 100%;
				border-collapse: collapse;
				min-width: 900px;
			}

			.compare-table th {
				background: var(--bg-tertiary);
				color: var(--text-secondary);
				font-weight: 600;
				font-size: var(--font-xs);
				text-transform: uppercase;
				letter-spacing: 0.05em;
				padding: 0.85rem 1rem;
				text-align: left;
				border-bottom: 1px solid var(--border-primary);
				white-space: nowrap;
				position: sticky;
				top: 0;
			}

			.compare-table td {
				padding: 0.85rem 1rem;
				border-bottom: 1px solid var(--border-secondary);
				vertical-align: top;
			}

			.compare-table tr:last-child td {
				border-bottom: none;
			}

			.compare-table tr:hover td {
				background: var(--bg-elevated);
			}

			.model-cell {
				display: flex;
				align-items: center;
				gap: 0.75rem;
			}

			.model-dot {
				width: 10px;
				height: 10px;
				border-radius: 50%;
				flex-shrink: 0;
			}

			.model-name {
				font-weight: 600;
				color: var(--text-primary);
				font-size: var(--font-sm);
			}

			.model-provider {
				font-size: var(--font-xs);
				color: var(--text-tertiary);
			}

			.price-cell {
				font-family: ui-monospace, monospace;
				font-size: var(--font-sm);
			}

			.price-cell .input {
				color: var(--text-secondary);
			}

			.price-cell .sep {
				color: var(--text-tertiary);
				margin: 0 0.25rem;
			}

			.price-cell .output {
				color: var(--text-tertiary);
			}

			.context-cell {
				font-family: ui-monospace, monospace;
				font-size: var(--font-sm);
				color: var(--text-secondary);
			}

			.score-cell {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}

			.score-row {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: var(--font-xs);
			}

			.score-label {
				color: var(--text-tertiary);
				width: 50px;
			}

			.score-bar {
				flex: 1;
				height: 4px;
				background: var(--bg-tertiary);
				border-radius: 2px;
				overflow: hidden;
				min-width: 40px;
			}

			.score-fill {
				height: 100%;
				border-radius: 2px;
			}

			.score-value {
				font-weight: 600;
				color: var(--text-primary);
				width: 28px;
				text-align: right;
			}

			.best-for-cell {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem;
			}

			.best-for-tag {
				font-size: var(--font-xs);
				padding: 0.2rem 0.5rem;
				background: var(--bg-tertiary);
				border-radius: var(--radius-sm);
				color: var(--text-secondary);
			}

			.use-case-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: var(--space-md);
			}

			.use-case-card {
				background: var(--bg-card);
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-lg);
				padding: var(--space-lg);
				transition: all var(--transition-base);
			}

			.use-case-card:hover {
				border-color: var(--border-accent);
				transform: translateY(-2px);
			}

			.use-case-emoji {
				font-size: 1.5rem;
				margin-bottom: 0.5rem;
			}

			.use-case-card h3 {
				font-size: var(--font-base);
				margin-bottom: 0.25rem;
			}

			.use-case-pick {
				font-size: var(--font-lg);
				font-weight: 700;
				color: var(--accent-light);
				margin-bottom: 0.5rem;
			}

			.use-case-reason {
				font-size: var(--font-sm);
				color: var(--text-tertiary);
				margin-bottom: 0.5rem;
				line-height: 1.5;
			}

			.use-case-alt {
				font-size: var(--font-xs);
				color: var(--text-tertiary);
			}

			.use-case-alt span {
				color: var(--text-secondary);
			}

			.strengths-cell ul {
				margin: 0;
				padding: 0;
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}

			.strengths-cell li {
				font-size: var(--font-xs);
				color: var(--text-tertiary);
				padding-left: 0.85rem;
				position: relative;
			}

			.strengths-cell li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 6px;
				width: 4px;
				height: 4px;
				border-radius: 50%;
				background: var(--accent);
			}

			.source-links {
				display: flex;
				flex-direction: column;
				gap: 0.35rem;
			}

			.source-links a {
				font-size: var(--font-sm);
				color: var(--accent-light);
			}

			.cta-section {
				padding: var(--space-2xl) 0;
			}

			.cta-card {
				background: var(--bg-card);
				border: 1px solid var(--border-accent);
				border-radius: var(--radius-xl);
				padding: var(--space-2xl);
				text-align: center;
				position: relative;
				overflow: hidden;
			}

			.cta-card::before {
				content: '';
				position: absolute;
				inset: 0;
				background: var(--gradient-card);
				pointer-events: none;
			}

			.cta-card h2 {
				position: relative;
				margin-bottom: var(--space-sm);
			}

			.cta-card p {
				position: relative;
				color: var(--text-secondary);
				margin-bottom: var(--space-lg);
				max-width: 500px;
				margin-left: auto;
				margin-right: auto;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.7rem 1.4rem;
				border-radius: var(--radius-md);
				font-weight: 600;
				font-size: var(--font-sm);
				text-decoration: none;
				transition: all var(--transition-fast);
				cursor: pointer;
				border: none;
				position: relative;
			}

			.btn-primary {
				background: var(--gradient-primary);
				color: white;
				box-shadow: 0 0 24px rgba(99, 102, 241, 0.3);
			}

			.btn-primary:hover {
				transform: translateY(-2px);
				box-shadow: 0 0 36px rgba(99, 102, 241, 0.5);
				color: white;
			}

			.btn-secondary {
				background: var(--bg-tertiary);
				color: var(--text-primary);
				border: 1px solid var(--border-primary);
				margin-left: 0.5rem;
			}

			.btn-secondary:hover {
				background: var(--bg-elevated);
				border-color: var(--border-accent);
				color: var(--text-primary);
			}

			.btn-arrow {
				transition: transform var(--transition-fast);
			}

			.btn:hover .btn-arrow {
				transform: translateX(3px);
			}

			.quick-links {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: var(--space-lg);
			}

			.quick-link {
				font-size: var(--font-sm);
				padding: 0.35rem 0.75rem;
				background: var(--bg-tertiary);
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-sm);
				color: var(--text-secondary);
				text-decoration: none;
				transition: all var(--transition-fast);
			}

			.quick-link:hover {
				background: var(--bg-elevated);
				border-color: var(--border-accent);
				color: var(--accent-light);
			}

			@media (max-width: 960px) {
				.use-case-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 600px) {
				.page-hero {
					padding: var(--space-xl) 0;
				}

				.hero-text h1 {
					font-size: 1.5rem;
				}

				.hero-text > p {
					font-size: var(--font-base);
				}

				.section {
					padding: var(--space-lg) 1rem;
				}

				.use-case-grid {
					grid-template-columns: 1fr;
				}

				.use-case-card {
					padding: var(--space-md);
				}

				.cta-card {
					padding: var(--space-lg);
				}

				.cta-card h2 {
					font-size: var(--font-xl);
				}

				.quick-links {
					justify-content: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<section class="page-hero">
			<div class="hero-inner">
				<div class="hero-text">
					<h1>AI Model Comparison</h1>
					<p>Compare leading AI models side-by-side with provider-verified model names and pricing references.</p>
					<div class="hero-meta">
						<span class="hero-badge"><span class="count">{models.length}</span> models compared</span>
						<span class="hero-badge">Verified <span class="count">{MODEL_DATA_VERIFIED_ON}</span></span>
					</div>
					<div class="quick-links">
						<a href="#pricing" class="quick-link">Pricing</a>
						<a href="#performance" class="quick-link">Performance</a>
						<a href="#recommendations" class="quick-link">Quick Picks</a>
						<a href="#sources" class="quick-link">Sources</a>
					</div>
				</div>
			</div>
		</section>

		<main>
			<section class="section" id="pricing">
				<div class="section-header">
					<h2>Quick Reference: Pricing & Context</h2>
					<p>Input/output pricing per million tokens from provider docs. Notes are included where pricing tiers apply.</p>
				</div>
				<div class="compare-table-wrapper">
					<table class="compare-table">
						<thead>
							<tr>
								<th>Model</th>
								<th>Pricing ($/M tokens)</th>
								<th>Context</th>
								<th>Best For</th>
							</tr>
						</thead>
						<tbody>
							{models.map((model) => (
								<tr>
									<td>
										<div class="model-cell">
											<div class="model-dot" style={`background: ${model.color}`}></div>
											<div>
												<div class="model-name">{model.name}</div>
												<div class="model-provider">{model.provider}</div>
											</div>
										</div>
									</td>
									<td>
										<div class="price-cell">
											<span class="input">${model.pricing.input}</span>
											<span class="sep">/</span>
											<span class="output">${model.pricing.output}</span>
										</div>
										{model.pricing.notes && (
											<div class="model-provider">{model.pricing.notes}</div>
										)}
									</td>
									<td>
										<span class="context-cell">{model.contextWindow}</span>
									</td>
									<td>
										<div class="best-for-cell">
											{model.bestFor.map((tag) => (
												<span class="best-for-tag">{tag}</span>
											))}
										</div>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>

			<section class="section" id="performance">
				<div class="section-header">
					<h2>Performance Scores</h2>
					<p>Internal task-level evaluations across coding, reasoning, and tool-use (scale: 1-10).</p>
				</div>
				<div class="compare-table-wrapper">
					<table class="compare-table">
						<thead>
							<tr>
								<th>Model</th>
								<th>Coding</th>
								<th>Reasoning</th>
								<th>Tool-use</th>
								<th>Key Strengths</th>
							</tr>
						</thead>
						<tbody>
							{models.map((model) => (
								<tr>
									<td>
										<div class="model-cell">
											<div class="model-dot" style={`background: ${model.color}`}></div>
											<div>
												<div class="model-name">{model.name}</div>
												<div class="model-provider">{model.provider}</div>
											</div>
										</div>
									</td>
									<td>
										<div class="score-cell">
											<div class="score-row">
												<div class="score-bar">
													<div class="score-fill" style={`width: ${model.scores.coding * 10}%; background: ${model.color}`}></div>
												</div>
												<span class="score-value">{model.scores.coding}</span>
											</div>
										</div>
									</td>
									<td>
										<div class="score-cell">
											<div class="score-row">
												<div class="score-bar">
													<div class="score-fill" style={`width: ${model.scores.reasoning * 10}%; background: ${model.color}`}></div>
												</div>
												<span class="score-value">{model.scores.reasoning}</span>
											</div>
										</div>
									</td>
									<td>
										<div class="score-cell">
											<div class="score-row">
												<div class="score-bar">
													<div class="score-fill" style={`width: ${model.scores.toolUse * 10}%; background: ${model.color}`}></div>
												</div>
												<span class="score-value">{model.scores.toolUse}</span>
											</div>
										</div>
									</td>
									<td class="strengths-cell">
										<ul>
											{model.strengths.map((s) => (
												<li>{s}</li>
											))}
										</ul>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>

			<section class="section" id="recommendations">
				<div class="section-header">
					<h2>Quick Pick Recommendations</h2>
					<p>Not sure which model? Here's our picks by use case.</p>
				</div>
				<div class="use-case-grid">
					{useCases.map((uc) => (
						<div class="use-case-card">
							<span class="use-case-emoji" set:html={uc.emoji} />
							<h3>{uc.title}</h3>
							<div class="use-case-pick">{uc.pick}</div>
							<p class="use-case-reason">{uc.reason}</p>
							<p class="use-case-alt">Alternative: <span>{uc.alternative}</span></p>
						</div>
					))}
				</div>
			</section>

			<section class="section" id="sources">
				<div class="section-header">
					<h2>Verification Sources</h2>
					<p>Official model and pricing references checked on {MODEL_DATA_VERIFIED_ON}.</p>
				</div>
				<div class="compare-table-wrapper">
					<table class="compare-table">
						<thead>
							<tr>
								<th>Model</th>
								<th>Official Sources</th>
							</tr>
						</thead>
						<tbody>
							{models.map((model) => (
								<tr>
									<td>
										<div class="model-cell">
											<div class="model-dot" style={`background: ${model.color}`}></div>
											<div>
												<div class="model-name">{model.name}</div>
												<div class="model-provider">{model.provider}</div>
											</div>
										</div>
									</td>
									<td>
										<div class="source-links">
											{model.sources.map((source) => (
												<a href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a>
											))}
										</div>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>

			<section class="cta-section container">
				<div class="cta-card">
					<h2>Dive Deeper into Model Performance</h2>
					<p>See detailed daily scorecards with task-level breakdowns, failure cases, and cost analysis.</p>
					<a class="btn btn-primary" href="/scorecards">
						View Daily Scorecards
						<span class="btn-arrow">&rarr;</span>
					</a>
					<a class="btn btn-secondary" href="/about">Our Methodology</a>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
