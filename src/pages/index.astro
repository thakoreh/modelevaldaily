---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { MODEL_DATA_VERIFIED_ON, VERIFIED_MODELS } from '../data/verified-models';
import { isFactCheckedPost } from '../utils/fact-check';

const score = (model: (typeof VERIFIED_MODELS)[number]) => model.scores.coding * 0.4 + model.scores.reasoning * 0.35 + model.scores.toolUse * 0.25;
const leaders = VERIFIED_MODELS.slice().sort((a, b) => score(b) - score(a)).slice(0, 6);
const articles = (await getCollection('blog'))
	.filter((post) => !post.id.includes('template') && isFactCheckedPost(post))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const decisions = [
	{ label: 'Coding & agents', title: 'Ship reliable code changes', detail: 'Prioritize coding quality, tool use, and long-context repo work.', href: '/use-cases/coding/', code: '01' },
	{ label: 'Reasoning', title: 'Solve difficult, constrained work', detail: 'Compare reasoning depth without hiding latency and price tradeoffs.', href: '/use-cases/reasoning/', code: '02' },
	{ label: 'High volume', title: 'Control inference cost', detail: 'Find the quality floor that meets your workload at production scale.', href: '/use-cases/cost-optimization/', code: '03' },
	{ label: 'Private deployment', title: 'Run open weights locally', detail: 'Balance privacy, hardware requirements, and operational overhead.', href: '/local-models/', code: '04' },
];
---
<!doctype html>
<html lang="en">
	<head><BaseHead title="AI Model Benchmarks 2026: Compare GPT, Claude, Gemini & DeepSeek" description="Compare AI model benchmarks for coding, agents, reasoning, context windows, and API pricing. Updated source-reviewed rankings for GPT, Claude, Gemini, DeepSeek, and open models." /></head>
	<body>
		<Header />
		<main class="home">
			<section class="hero container">
				<div class="hero-copy">
					<span class="eyebrow">Independent model decision guide</span>
					<h1>AI Model Benchmarks</h1>
					<p>Compare capability, cost, context, and deployment tradeoffs with source-aware guidance built for people shipping real AI systems.</p>
					<div class="hero-actions">
						<a class="btn btn-primary" href="/tools/model-picker/" data-analytics="model_picker_start" data-analytics-label="Homepage hero">Find my model <span aria-hidden="true">-&gt;</span></a>
						<a class="btn btn-secondary" href="/compare/">Compare models</a>
					</div>
				</div>
				<aside class="briefing" aria-label="Current model briefing">
					<div class="briefing-head"><div><span class="kicker">Today's short list</span><h2>Frontier model briefing</h2></div><span class="status"><i></i> Reviewed {MODEL_DATA_VERIFIED_ON}</span></div>
					<ol>
						{leaders.slice(0, 4).map((model, index) => (
							<li><span class="rank mono">{String(index + 1).padStart(2, '0')}</span><div><strong>{model.name}</strong><span>{model.bestFor.slice(0, 2).join(' / ')}</span></div><b class="mono">{score(model).toFixed(1)}</b></li>
						))}
					</ol>
					<div class="briefing-foot"><span>Editorial fit score: coding 40% / reasoning 35% / tool use 25%</span><a href="/models/">Open rankings -&gt;</a></div>
				</aside>
			</section>

			<section class="trust-strip">
				<div class="container trust-grid">
					<div><span class="mono">{VERIFIED_MODELS.length}</span><p>models tracked</p></div>
					<div><span class="mono">{new Set(VERIFIED_MODELS.map((model) => model.provider)).size}</span><p>providers reviewed</p></div>
					<div><span class="mono">{MODEL_DATA_VERIFIED_ON}</span><p>latest source review</p></div>
					<a href="/model-data/"><span>Methodology</span><p>See sources and caveats -&gt;</p></a>
				</div>
			</section>

			<section class="section container">
				<div class="section-intro"><div><span class="eyebrow">Start with the workload</span><h2>What are you trying to do?</h2></div><p>A benchmark only matters when it resembles your constraints. Choose a decision path before choosing a winner.</p></div>
				<div class="decision-grid">
					{decisions.map((item) => <a class="decision" href={item.href}><span class="decision-code mono">{item.code}</span><span class="decision-label">{item.label}</span><h3>{item.title}</h3><p>{item.detail}</p><b>Explore the guide <span aria-hidden="true">-&gt;</span></b></a>)}
				</div>
			</section>

			<section class="section ranking-section">
				<div class="container">
					<div class="section-intro"><div><span class="eyebrow">Comparable at a glance</span><h2>The current leaderboard</h2></div><p>One editorial composite for orientation, with the underlying dimensions, price, and source trail kept visible.</p></div>
					<div class="table-shell">
						<table>
							<thead><tr><th>Rank</th><th>Model</th><th>Editorial fit</th><th>Coding</th><th>Reasoning</th><th>Tool use</th><th>Input / output</th></tr></thead>
							<tbody>{leaders.map((model, index) => <tr><td class="mono faint">{String(index + 1).padStart(2, '0')}</td><td><strong>{model.name}</strong><span>{model.provider}</span></td><td><b class="score mono">{score(model).toFixed(1)}</b></td><td class="mono">{model.scores.coding.toFixed(1)}</td><td class="mono">{model.scores.reasoning.toFixed(1)}</td><td class="mono">{model.scores.toolUse.toFixed(1)}</td><td class="mono price">${model.pricing.input} / ${model.pricing.output}</td></tr>)}</tbody>
						</table>
					</div>
					<div class="ranking-actions"><p>Scores are editorial decision aids, not universal benchmark claims.</p><a class="btn btn-secondary" href="/models/">View all models -&gt;</a></div>
				</div>
			</section>

			<section class="section container methodology">
				<div class="method-copy"><span class="eyebrow">How to read the data</span><h2>Evidence before verdicts.</h2><p>Model choice is multidimensional. We separate source-backed specifications from editorial interpretation, date every review, and show caveats where provider tiers or deployment choices change the answer.</p><a href="/model-data/">Read the methodology -&gt;</a></div>
				<div class="method-list"><div><span class="mono">01</span><h3>Verify the facts</h3><p>Pricing, context, availability, and release details link back to provider or benchmark sources.</p></div><div><span class="mono">02</span><h3>Expose the weights</h3><p>Composite scores state what they reward so you can decide whether the ranking fits your job.</p></div><div><span class="mono">03</span><h3>Name the tradeoffs</h3><p>Every recommendation should include a reason to choose it and a reason not to.</p></div></div>
			</section>

			{articles.length > 0 && <section class="section research-section"><div class="container"><div class="section-intro"><div><span class="eyebrow">Research notes</span><h2>Recent evaluations</h2></div><a href="/blog/">Browse all research -&gt;</a></div><div class="article-grid">{articles.map((post) => <a href={`/blog/${post.id}/`}><span class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</span><h3>{post.data.title}</h3><p>{post.data.description}</p><b>Read analysis -&gt;</b></a>)}</div></div></section>}
		</main>
		<Footer />
	</body>
</html>

<style>
	.home { width: 100%; max-width: none; padding: 0; }
	.hero { min-height: 560px; padding-block: 5rem 3.5rem; display: grid; grid-template-columns: minmax(0, 0.9fr) minmax(460px, 1.1fr); gap: clamp(2.5rem, 6vw, 6rem); align-items: center; }
	.hero-copy h1 { max-width: 720px; font-size: clamp(3rem, 6vw, 5.6rem); line-height: 0.98; }
	.hero-copy > p { max-width: 610px; margin: 1.35rem 0 1.65rem; font-size: 1.08rem; line-height: 1.58; }
	.hero-actions { display: flex; gap: 0.7rem; flex-wrap: wrap; }
	.briefing { border: 1px solid var(--line-strong); border-radius: var(--radius-xl); background: var(--surface); box-shadow: var(--shadow-lg); overflow: hidden; }
	.briefing-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; padding: 1.2rem 1.25rem; border-bottom: 1px solid var(--line); background: var(--ink); color: #fff; }
	.briefing-head h2 { margin: 0.2rem 0 0; color: #fff; font: 720 1.1rem var(--font-sans); }
	.kicker { color: var(--ink-faint); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; }
	.briefing-head .kicker { color: rgba(255,255,255,0.62); }
	.status { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--green); font-size: 0.72rem; white-space: nowrap; }
	.status i { width: 7px; height: 7px; border-radius: 50%; background: var(--green); }
	.briefing ol { list-style: none; margin: 0; padding: 0; }
	.briefing li { display: grid; grid-template-columns: 34px 1fr auto; gap: 0.8rem; align-items: center; padding: 0.88rem 1.25rem; border-bottom: 1px solid var(--line); }
	.briefing li div { min-width: 0; display: flex; flex-direction: column; }
	.briefing li div span { overflow: hidden; color: var(--ink-faint); font-size: 0.78rem; text-overflow: ellipsis; white-space: nowrap; }
	.rank { color: var(--ink-faint); font-size: 0.76rem; }
	.briefing li > b { font-size: 1.05rem; }
	.briefing-foot { padding: 0.9rem 1.25rem; display: flex; justify-content: space-between; gap: 1rem; color: var(--ink-faint); font-size: 0.72rem; background: var(--surface-subtle); }
	.briefing-foot a { white-space: nowrap; }
	.trust-strip { border-block: 1px solid var(--line); background: var(--surface); }
	.trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
	.trust-grid > * { min-height: 102px; padding: 1.35rem; border-right: 1px solid var(--line); text-decoration: none; }
	.trust-grid > *:last-child { border: 0; }
	.trust-grid span { display: block; color: var(--ink); font-size: 1.2rem; font-weight: 650; }
	.trust-grid p { margin: 0.25rem 0 0; font-size: 0.8rem; }
	.section { padding-block: 5rem; }
	.section-intro { margin-bottom: 2.5rem; display: grid; grid-template-columns: 1fr minmax(300px, 0.7fr); gap: 3rem; align-items: end; }
	.section-intro h2 { margin: 0; }
	.section-intro > p { margin: 0; }
	.decision-grid { display: grid; grid-template-columns: repeat(4, 1fr); border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
	.decision { min-height: 285px; padding: 1.45rem; border-right: 1px solid var(--line); display: flex; flex-direction: column; color: var(--ink); text-decoration: none; background: var(--surface); transition: background var(--transition-base), transform var(--transition-fast); }
	.decision:last-child { border: 0; }
	.decision:hover { background: var(--blue-soft); transform: translateY(-1px); }
	.decision-code { color: var(--ink-faint); font-size: 0.72rem; }
	.decision-label { margin-top: auto; color: var(--green); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
	.decision h3 { margin-top: 0.45rem; font-size: 1.25rem; }
	.decision p { font-size: 0.88rem; }
	.decision b { margin-top: 0.7rem; color: var(--blue); font-size: 0.84rem; }
	.ranking-section { border-block: 1px solid var(--line); background: var(--surface-subtle); }
	.table-shell { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius-lg); background: var(--surface); box-shadow: var(--shadow-md); }
	.table-shell table { min-width: 880px; }
	.table-shell td strong, .table-shell td span { display: block; }
	.table-shell td span { color: var(--ink-faint); font-size: 0.74rem; }
	.faint { color: var(--ink-faint); }
	.score { color: var(--blue); font-size: 1rem; }
	.price { white-space: nowrap; }
	.ranking-actions { margin-top: 1rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
	.ranking-actions p { margin: 0; font-size: 0.78rem; }
	.methodology { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 5rem; }
	.method-copy { position: sticky; top: 7rem; align-self: start; }
	.method-copy p { margin-top: 1.4rem; }
	.method-list { border-top: 1px solid var(--line-strong); }
	.method-list > div { display: grid; grid-template-columns: 50px 0.6fr 1fr; gap: 1.2rem; padding: 1.5rem 0; border-bottom: 1px solid var(--line); }
	.method-list span { color: var(--ink-faint); font-size: 0.72rem; }
	.method-list h3 { font-size: 1rem; }
	.method-list p { margin: 0; font-size: 0.88rem; }
	.research-section { border-top: 1px solid var(--line); }
	.article-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
	.article-grid > a { min-height: 235px; padding: 1.4rem; border: 1px solid var(--line); border-radius: var(--radius-lg); display: flex; flex-direction: column; color: var(--ink); text-decoration: none; background: var(--surface); }
	.article-grid h3 { margin-top: 1rem; font: 680 1.2rem var(--font-sans); }
	.article-grid p { font-size: 0.86rem; }
	.article-grid b { margin-top: auto; color: var(--blue); font-size: 0.82rem; }
	@media (max-width: 1000px) { .hero { grid-template-columns: 1fr; } .briefing { max-width: 720px; } .decision-grid { grid-template-columns: 1fr 1fr; } .decision:nth-child(2) { border-right: 0; } .decision:nth-child(-n+2) { border-bottom: 1px solid var(--line); } .methodology { gap: 3rem; } }
	@media (max-width: 720px) { .hero { min-height: auto; padding-block: 3rem 2.5rem; } .hero-copy h1 { font-size: clamp(2.8rem, 13vw, 4rem); } .hero-copy > p { font-size: 1rem; } .briefing-head, .briefing-foot { align-items: flex-start; flex-direction: column; } .trust-grid { grid-template-columns: 1fr 1fr; } .trust-grid > * { border-bottom: 1px solid var(--line); } .trust-grid > *:nth-child(2) { border-right: 0; } .section { padding-block: 3.5rem; } .section-intro { grid-template-columns: 1fr; gap: 1rem; } .decision-grid, .article-grid, .methodology { grid-template-columns: 1fr; } .decision { min-height: 220px; border-right: 0; border-bottom: 1px solid var(--line); } .decision:last-child { border-bottom: 0; } .method-copy { position: static; } .method-list > div { grid-template-columns: 36px 1fr; } .method-list p { grid-column: 2; } .ranking-actions { align-items: flex-start; flex-direction: column; } }
</style>
