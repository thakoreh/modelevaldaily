---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { MODEL_DATA_VERIFIED_ON, VERIFIED_MODELS } from '../data/verified-models';
import { isFactCheckedPost } from '../utils/fact-check';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
// Exclude templates from public lists
const posts = allPosts.filter((p) => !p.id.includes('template') && isFactCheckedPost(p));
const latest = posts[0];
const recent = posts.slice(0, 6);

// Get latest scorecard for leaderboard
const scorecardPosts = posts.filter(p => p.id.includes('scorecard') || p.data.title.toLowerCase().includes('scorecard'));
const latestScorecard = scorecardPosts.length > 0 ? scorecardPosts[0] : null;

// Use verified models data directly (more reliable than parsing markdown)
const models = VERIFIED_MODELS.slice(0, 5).map(model => ({
	name: model.name,
	total: (model.scores.coding * 0.4 + model.scores.reasoning * 0.35 + model.scores.toolUse * 0.25),
	color: model.color
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Verified AI Model Scorecards`} description={SITE_DESCRIPTION} />
		<style>
			/* Override main for homepage — full-width sections */
			main {
				width: 100%;
				max-width: 100%;
				padding: 0;
			}

			/* Shared container */
			.container {
				max-width: var(--container-xl);
				margin: 0 auto;
				padding: 0 1.5rem;
			}

			/* ===== HERO ===== */
			.hero-section {
				position: relative;
				padding: 4.6rem 0 3.5rem;
				overflow: hidden;
				border-bottom: 1px solid var(--border-secondary);
			}
			.hero-bg {
				position: absolute;
				inset: 0;
				background: var(--gradient-hero);
				pointer-events: none;
			}
			.hero-mesh {
				position: absolute;
				inset: 0;
				background: var(--gradient-mesh);
				opacity: 0.42;
				pointer-events: none;
			}
			.hero-grid-lines {
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(rgba(244,241,232,0.022) 1px, transparent 1px),
					linear-gradient(90deg, rgba(244,241,232,0.022) 1px, transparent 1px);
				background-size: 72px 72px;
				pointer-events: none;
			}
			.hero-content {
				position: relative;
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(360px, 0.92fr);
				gap: 4rem;
				align-items: center;
			}
			.hero-text {
				opacity: 0;
				animation: fadeInUp 0.7s ease-out 0.1s forwards;
			}
			.hero-eyebrow {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-size: var(--font-xs);
				font-weight: 700;
				letter-spacing: 0;
				color: var(--accent-light);
				margin-bottom: var(--space-md);
				padding: 0.35rem 0.85rem;
				background: rgba(20, 184, 166, 0.1);
				border: 1px solid var(--border-accent);
				border-radius: var(--radius-md);
			}
			.hero-eyebrow .dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--success);
				animation: pulse 2s ease-in-out infinite;
			}
			.hero-title {
				font-size: clamp(2.65rem, 4.7vw, 4.35rem);
				line-height: 1.02;
				margin-bottom: var(--space-lg);
				letter-spacing: 0;
				color: var(--text-primary);
				background: none;
				-webkit-text-fill-color: currentColor;
			}
			.hero-desc {
				font-size: 1.05rem;
				color: var(--text-secondary);
				line-height: 1.65;
				max-width: 620px;
				margin-bottom: var(--space-xl);
			}
			.hero-badges {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: var(--space-xl);
			}
			.hero-badges .badge {
				white-space: nowrap;
			}
			.hero-actions {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
			}

			/* Buttons */
			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				min-height: 44px;
				padding: 0.72rem 1.1rem;
				border-radius: var(--radius-md);
				font-weight: 700;
				font-size: var(--font-sm);
				text-decoration: none;
				transition: all var(--transition-fast);
				cursor: pointer;
				border: none;
			}
			.btn-primary {
				background: var(--accent);
				color: var(--text-inverse);
				box-shadow: none;
			}
			.btn-primary:hover {
				transform: translateY(-2px);
				box-shadow: 0 14px 30px rgba(20, 184, 166, 0.16);
				color: var(--text-inverse);
			}
			.btn-secondary {
				background: rgba(244, 241, 232, 0.05);
				color: var(--text-primary);
				border: 1px solid var(--border-primary);
			}
			.btn-secondary:hover {
				background: var(--bg-elevated);
				border-color: var(--border-accent);
				color: var(--text-primary);
			}
			.btn-arrow {
				transition: transform var(--transition-fast);
			}
			.btn:hover .btn-arrow {
				transform: translateX(3px);
			}

			/* ===== LEADERBOARD CARD ===== */
			.hero-visual {
				opacity: 0;
				animation: fadeInUp 0.7s ease-out 0.3s forwards;
			}
			.leaderboard-card {
				background: linear-gradient(180deg, rgba(25, 28, 23, 0.96), rgba(15, 17, 14, 0.96));
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-xl);
				padding: 1.35rem;
				box-shadow: var(--shadow-lg);
				position: relative;
				overflow: hidden;
			}
			.leaderboard-link {
				position: absolute;
				inset: 0;
				z-index: 1;
			}
			.model-row {
				display: grid;
				grid-template-columns: auto 1fr auto;
				gap: var(--space-md);
				align-items: center;
				padding: 0.75rem 0;
				border-bottom: 1px solid var(--border-secondary);
				min-width: 0;
			}
			.model-row:last-of-type {
				border-bottom: none;
			}
			.model-name {
				font-weight: 600;
				font-size: var(--font-sm);
				color: var(--text-primary);
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.leaderboard-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 3px;
				background: linear-gradient(90deg, var(--accent), var(--accent-2), var(--accent-3));
				opacity: 0.88;
			}
			.leaderboard-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: var(--space-md);
			}
			.leaderboard-header h3 {
				font-size: var(--font-base);
				color: var(--text-primary);
				margin: 0;
			}
			.leaderboard-header span {
				font-size: var(--font-xs);
				color: var(--text-tertiary);
			}
			.model-rank {
				width: 28px;
				height: 28px;
				display: flex;
				align-items: center;
				justify-content: center;
				border-radius: var(--radius-md);
				font-size: var(--font-xs);
				font-weight: 700;
				background: rgba(244, 241, 232, 0.06);
				color: var(--text-secondary);
			}
			.model-rank.gold {
				background: rgba(245, 158, 11, 0.16);
				color: var(--warning);
			}
			.model-info {
				display: flex;
				flex-direction: column;
				gap: 0.15rem;
			}
			.model-name {
				font-weight: 600;
				font-size: var(--font-sm);
				color: var(--text-primary);
			}
			.model-bar-container {
				height: 6px;
				background: rgba(244, 241, 232, 0.08);
				border-radius: 3px;
				overflow: hidden;
				margin-top: 0.2rem;
			}
			.model-bar {
				height: 100%;
				border-radius: 3px;
				transition: width 1s ease-out;
			}
			.model-score {
				font-size: var(--font-lg);
				font-weight: 700;
				color: var(--text-primary);
			}
			.leaderboard-footer {
				margin-top: var(--space-md);
				padding-top: var(--space-sm);
				border-top: 1px solid var(--border-secondary);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.leaderboard-footer a {
				font-size: var(--font-xs);
				color: var(--accent-light);
			}
			.leaderboard-footer span {
				font-size: var(--font-xs);
				color: var(--text-tertiary);
			}

			/* ===== STATS STRIP ===== */
			.stats-strip {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1px;
				padding: 0;
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-lg);
				overflow: hidden;
				background: var(--border-primary);
			}
			.stat-card {
				background: rgba(18, 20, 16, 0.95);
				border: 0;
				border-radius: 0;
				padding: 1.25rem;
				text-align: left;
				transition: all var(--transition-base);
			}
			.stat-card:hover {
				background: var(--bg-card-hover);
				transform: none;
			}
			.stat-number {
				font-size: var(--font-2xl);
				font-weight: 700;
				color: var(--text-primary);
				line-height: 1;
				margin-bottom: 0.35rem;
			}
			.stat-label {
				font-size: var(--font-sm);
				color: var(--text-tertiary);
			}

			/* ===== SECTIONS ===== */
			.section {
				padding: 3.25rem 0;
			}
			.section-header {
				margin-bottom: var(--space-xl);
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: var(--space-xl);
			}
			.section-header h2 {
				margin-bottom: 0.35rem;
			}
			.section-header p {
				color: var(--text-tertiary);
				font-size: var(--font-base);
				max-width: 560px;
				margin: 0;
			}

			/* ===== POST GRID ===== */
			.post-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}
			.post-card {
				background: rgba(18, 20, 16, 0.88);
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-lg);
				overflow: hidden;
				text-decoration: none;
				color: inherit;
				transition: all var(--transition-base);
				display: flex;
				flex-direction: column;
			}
			.post-card:hover {
				border-color: var(--border-accent);
				transform: translateY(-3px);
				box-shadow: var(--shadow-lg);
			}
			.post-card:hover .post-card-title {
				color: var(--accent-light);
			}
			.post-card-image {
				aspect-ratio: 16/9;
				overflow: hidden;
			}
			.post-card-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				transition: transform var(--transition-slow);
			}
			.post-card:hover .post-card-image img {
				transform: scale(1.05);
			}
			.post-card-body {
				padding: var(--space-lg);
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			.post-card-date {
				font-size: var(--font-xs);
				color: var(--text-tertiary);
				margin-bottom: 0.35rem;
			}
			.post-card-title {
				font-size: var(--font-base);
				font-weight: 600;
				color: var(--text-primary);
				line-height: 1.35;
				margin: 0;
				transition: color var(--transition-fast);
			}

			/* ===== TRUST GRID ===== */
			.trust-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}
			/* How It Works - 4 columns on desktop */
			.trust-grid.how-it-works {
				grid-template-columns: repeat(4, 1fr);
			}
			.trust-card {
				background: rgba(18, 20, 16, 0.88);
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-lg);
				padding: 1.35rem;
				transition: all var(--transition-base);
				position: relative;
				overflow: hidden;
			}
			.trust-card::before {
				content: none;
			}
			.trust-card:hover {
				border-color: var(--border-accent);
				transform: translateY(-3px);
			}
			.trust-icon {
				width: 40px;
				height: 40px;
				border-radius: var(--radius-md);
				background: rgba(20, 184, 166, 0.1);
				border: 1px solid var(--border-primary);
				display: flex;
				align-items: center;
				justify-content: center;
				margin-bottom: var(--space-md);
				font-size: 1.2rem;
				position: relative;
			}
			.trust-card h3 {
				font-size: var(--font-base);
				margin-bottom: 0.5rem;
			}
			.trust-card p {
				font-size: var(--font-sm);
				color: var(--text-tertiary);
				margin: 0;
				line-height: 1.6;
			}

			/* ===== FIELDS TABLE ===== */
			.fields-section {
				background: linear-gradient(180deg, rgba(18, 20, 16, 0.94), rgba(16, 17, 15, 0.94));
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-xl);
				padding: var(--space-2xl);
				overflow-x: auto;
			}
			.fields-section h2 {
				margin-bottom: var(--space-lg);
			}

			/* ===== NEW PAGES SECTION ===== */
			.provider-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
			}
			.provider-card {
				background: rgba(18, 20, 16, 0.9);
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-lg);
				padding: 1.35rem;
				text-decoration: none;
				color: inherit;
				transition: all var(--transition-base);
			}
			.provider-card:hover {
				border-color: var(--border-accent);
				transform: translateY(-3px);
			}
			.provider-card h3 {
				font-size: var(--font-lg);
				margin-bottom: var(--space-sm);
			}
			.provider-card p {
				font-size: var(--font-sm);
				color: var(--text-secondary);
			}
			.new-pages-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: var(--space-lg);
			}
			.new-page-card {
				background: linear-gradient(135deg, rgba(20, 184, 166, 0.14), rgba(245, 158, 11, 0.08)), var(--bg-card);
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-lg);
				padding: var(--space-xl);
				text-decoration: none;
				color: inherit;
				transition: all var(--transition-base);
			}
			.new-page-card:hover {
				border-color: var(--accent);
				transform: translateY(-4px);
			}
			.new-page-icon {
				font-size: 2rem;
				margin-bottom: var(--space-sm);
			}
			.new-page-card h3 {
				font-size: var(--font-lg);
				margin-bottom: var(--space-sm);
			}
			.new-page-card p {
				font-size: var(--font-sm);
				color: var(--text-secondary);
				margin-bottom: var(--space-md);
			}
			.new-page-link {
				font-size: var(--font-sm);
				font-weight: 600;
				color: var(--accent-light);
			}

			/* ===== CTA ===== */
			.cta-section {
				padding: var(--space-3xl) 0 var(--space-xl);
			}
			.cta-card {
				background: var(--bg-card);
				border: 1px solid var(--border-accent);
				border-radius: var(--radius-xl);
				padding: 2.5rem;
				text-align: center;
				position: relative;
				overflow: hidden;
			}
			.cta-card::before {
				content: '';
				position: absolute;
				inset: 0;
				background: var(--gradient-card);
				pointer-events: none;
			}
			.cta-card h2 {
				position: relative;
				margin-bottom: var(--space-sm);
			}
			.cta-card p {
				position: relative;
				color: var(--text-secondary);
				margin-bottom: var(--space-xl);
				max-width: 480px;
				margin-left: auto;
				margin-right: auto;
			}
			.cta-card .btn {
				position: relative;
			}

			/* ===== RESPONSIVE ===== */
			@media (max-width: 960px) {
				.hero-content {
					grid-template-columns: 1fr;
					gap: var(--space-2xl);
				}
				.hero-title {
					font-size: clamp(1.75rem, 5vw, 2.5rem);
				}
				.hero-desc {
					font-size: var(--font-base);
				}
				.post-grid {
					grid-template-columns: repeat(2, 1fr);
					gap: var(--space-md);
				}
				.trust-grid {
					grid-template-columns: 1fr;
				}
				/* How It Works - 2 columns on tablet */
				.trust-grid.how-it-works {
					grid-template-columns: repeat(2, 1fr);
				}
				.stats-strip {
					grid-template-columns: repeat(2, 1fr);
				}
				.leaderboard-footer {
					flex-direction: column;
					gap: var(--space-xs);
					text-align: center;
				}
			}
			@media (max-width: 600px) {
				.hero-section {
					padding: var(--space-xl) 0;
				}
				.hero-title {
					font-size: 2.15rem;
					line-height: 1.05;
				}
				.hero-badges {
					flex-wrap: wrap;
				}
				.hero-actions {
					flex-direction: column;
				}
				.hero-actions .btn {
					width: 100%;
					justify-content: center;
				}
				.post-grid {
					grid-template-columns: 1fr;
				}
				.stats-strip {
					grid-template-columns: 1fr 1fr;
					gap: var(--space-sm);
				}
				.stat-card {
					padding: var(--space-md);
				}
				.stat-number {
					font-size: var(--font-2xl);
				}
				.section {
					padding: var(--space-xl) 0;
				}
				.section-header {
					margin-bottom: var(--space-md);
					display: block;
				}
				.trust-card {
					padding: var(--space-lg);
				}
				/* How It Works - 1 column on mobile */
				.trust-grid.how-it-works {
					grid-template-columns: 1fr;
				}
				.fields-section {
					padding: var(--space-lg);
				}
				.fields-section table th,
				.fields-section table td {
					white-space: normal;
					min-width: 0;
				}
				.provider-grid {
					grid-template-columns: 1fr;
				}
				.cta-card {
					padding: var(--space-xl);
				}
				.cta-card h2 {
					font-size: var(--font-xl);
				}
				
				/* Mobile leaderboard - card view */
				.leaderboard-card {
					padding: var(--space-md);
				}
				.leaderboard-header h3 {
					font-size: var(--font-base);
				}
				.model-row {
					padding: var(--space-sm) 0;
					gap: var(--space-sm);
				}
				.model-name {
					font-size: var(--font-xs);
					max-width: 140px;
				}
				.model-score {
					font-size: var(--font-base);
				}
				.model-bar-container {
					display: none;
				}
				.leaderboard-footer {
					flex-direction: column;
					gap: var(--space-xs);
					text-align: center;
				}
				.leaderboard-footer span {
					font-size: 10px;
				}
			}
			
			/* Extra small devices (phones, 400px and below) */
			@media (max-width: 400px) {
				.hero-title {
					font-size: 2rem;
					line-height: 1.06;
				}
				.hero-desc {
					font-size: var(--font-sm);
				}
				.badge {
					font-size: 10px;
					padding: 0.25rem 0.5rem;
				}
				.leaderboard-card {
					border-radius: var(--radius-lg);
				}
				.model-rank {
					width: 24px;
					height: 24px;
					font-size: 10px;
				}
				.model-name {
					font-size: 11px;
					max-width: 110px;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="hero-section">
			<div class="hero-bg"></div>
			<div class="hero-mesh"></div>
			<div class="hero-grid-lines"></div>
			<div class="hero-content container">
				<div class="hero-text">
					<span class="hero-eyebrow">
						<span class="dot"></span>
						Model data verified {MODEL_DATA_VERIFIED_ON}
					</span>
					<h1 class="hero-title">Pick the right AI model with real-world benchmarks.</h1>
					<p class="hero-desc">
						We run actual engineering tasks — bug fixes, architecture decisions, API integrations — and score every model on <strong>correctness</strong>, <strong>cost</strong>, <strong>latency</strong>, and <strong>reliability</strong>. No synthetic benchmarks. No marketing claims. Just reproducible evals.
					</p>
					<div class="hero-badges">
