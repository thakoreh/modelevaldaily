---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import { MODEL_DATA_VERIFIED_ON, VERIFIED_MODELS } from '../data/verified-models';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Model Data Sources — Fact Check Log | ${SITE_TITLE}`}
			description={`Official model and pricing source references used on AI Model Benchmarks. Last verified on ${MODEL_DATA_VERIFIED_ON}.`}
		/>
		<style>
			main {
				width: 100%;
				max-width: 100%;
				padding: 0;
			}
			.container {
				max-width: var(--container-xl);
				margin: 0 auto;
				padding: 0 1.5rem;
			}
			.hero {
				padding: var(--space-3xl) 0 var(--space-xl);
			}
			.hero h1 {
				font-size: clamp(2rem, 3.5vw, 2.75rem);
				margin-bottom: var(--space-sm);
			}
			.hero p {
				font-size: var(--font-lg);
				color: var(--text-secondary);
				margin-bottom: var(--space-md);
			}
			.badge {
				display: inline-flex;
				align-items: center;
				padding: 0.35rem 0.75rem;
				border-radius: var(--radius-full);
				font-size: var(--font-xs);
				font-weight: 600;
				background: rgba(34, 197, 94, 0.1);
				color: var(--success);
				border: 1px solid rgba(34, 197, 94, 0.3);
			}
			.section {
				padding: var(--space-lg) 0 var(--space-3xl);
			}
			.table-wrap {
				border: 1px solid var(--border-primary);
				border-radius: var(--radius-xl);
				overflow: auto;
				background: var(--bg-card);
			}
			table {
				width: 100%;
				min-width: 760px;
			}
			th {
				white-space: nowrap;
			}
			.model-cell {
				display: flex;
				align-items: center;
				gap: 0.6rem;
			}
			.model-dot {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				flex-shrink: 0;
			}
			.model-provider {
				font-size: var(--font-xs);
				color: var(--text-tertiary);
			}
			.sources {
				display: flex;
				flex-direction: column;
				gap: 0.35rem;
			}
			.sources a {
				font-size: var(--font-sm);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero container">
				<h1>Model Data Sources</h1>
				<p>
					This page tracks the official provider docs used to validate model names and pricing displayed on
					this site. Benchmark scores are internal editorial scores; provider docs validate model availability,
					context windows, and token pricing.
				</p>
				<span class="badge">Last verified: {MODEL_DATA_VERIFIED_ON}</span>
			</section>

			<section class="section container">
				<div class="table-wrap">
					<table>
						<thead>
							<tr>
								<th>Model</th>
								<th>Pricing ($/M input/output)</th>
								<th>Notes</th>
								<th>Official Sources</th>
							</tr>
						</thead>
						<tbody>
							{VERIFIED_MODELS.map((model) => (
								<tr>
									<td>
										<div class="model-cell">
											<div class="model-dot" style={`background: ${model.color};`}></div>
											<div>
												<div>{model.name}</div>
												<div class="model-provider">{model.provider}</div>
											</div>
										</div>
									</td>
									<td>
										${model.pricing.input} / ${model.pricing.output}
									</td>
									<td>{model.pricing.notes ?? 'Standard published rate.'}</td>
									<td>
										<div class="sources">
											{model.sources.map((source) => (
												<a href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a>
											))}
										</div>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
