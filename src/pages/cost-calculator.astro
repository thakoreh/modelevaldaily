---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { allModels } from '../data/pricing';

const title = 'LLM Cost Calculator — Compare AI API Pricing by Scenario';
const description = 'Estimate monthly AI API costs across OpenAI, Anthropic, Google, Zhipu, and open-weight hosted models. Includes coding agent, RAG, support bot, and batch extraction presets.';
const uniqueModels = Array.from(new Map(allModels.map((model) => [`${model.provider}:${model.model}`, model])).values());
const models = uniqueModels.map((m) => ({ provider: m.provider, model: m.model, inputCost: m.inputCost, outputCost: m.outputCost, contextWindow: m.contextWindow, sourceUrl: m.sourceUrl, lastVerified: m.lastVerified, notes: m.notes ?? '' })).slice(0, 40);
---
<html lang="en">
<head><BaseHead title={title} description={description} type="website" /></head>
<body>
<Header />
<main class="page">
  <section class="hero"><div class="container">
    <p class="eyebrow">LLM cost planner</p>
    <h1>LLM Cost Calculator</h1>
    <p class="subtitle">Estimate real monthly API spend using requests/day, input tokens, output tokens, retry rate, and cache hit rate. Built for coding agents, RAG apps, support bots, and batch extraction jobs.</p>
    <div class="hero-actions"><a href="/tools/model-picker/" class="btn primary">Pick a model first</a><a href="/cheapest-ai-models/" class="btn secondary">See cheapest models</a></div>
  </div></section>

  <section class="container calc-grid">
    <form class="panel inputs" id="cost-form">
      <h2>Scenario</h2>
      <label>Preset
        <select id="preset">
          <option value="coding">Coding agent</option>
          <option value="rag">RAG chatbot</option>
          <option value="support">Customer support bot</option>
          <option value="batch">Batch extraction</option>
          <option value="custom">Custom</option>
        </select>
      </label>
      <div class="two"><label>Requests/day<input id="requests" type="number" min="1" value="250" /></label><label>Retry rate %<input id="retries" type="number" min="0" max="100" value="8" /></label></div>
      <div class="two"><label>Input tokens/request<input id="inputTokens" type="number" min="1" value="12000" /></label><label>Output tokens/request<input id="outputTokens" type="number" min="1" value="1800" /></label></div>
      <div class="two"><label>Cache hit %<input id="cache" type="number" min="0" max="95" value="25" /></label><label>Cached input discount %<input id="discount" type="number" min="0" max="95" value="75" /></label></div>
      <button type="button" id="calculate">Calculate monthly cost</button>
      <button type="button" id="copy-url" class="secondary-button">Copy shareable URL</button>
    </form>
    <aside class="panel summary">
      <p class="eyebrow">Usage estimate</p>
      <h2 id="monthly-requests">7,500 requests/mo</h2>
      <div class="metric"><span>Input tokens/mo</span><strong id="monthly-input">90M</strong></div>
      <div class="metric"><span>Output tokens/mo</span><strong id="monthly-output">13.5M</strong></div>
      <div class="metric"><span>Effective retry multiplier</span><strong id="retry-multiplier">1.08x</strong></div>
      <p class="muted">Pricing data is manually maintained from provider sources. Always check the official pricing page before committing production spend.</p>
    </aside>
  </section>

  <section class="container section">
    <h2>Model cost comparison</h2>
    <div class="table-wrap"><table><thead><tr><th>Model</th><th>Provider</th><th>Input</th><th>Output</th><th>Monthly estimate</th><th>Source</th></tr></thead><tbody id="results"></tbody></table></div>
  </section>
</main>
<Footer />
<script type="application/json" id="pricing-data" set:html={JSON.stringify(models)} />
<script>
  const models = JSON.parse(document.getElementById('pricing-data').textContent || '[]');
  const presets = {
    coding: { requests: 250, inputTokens: 12000, outputTokens: 1800, retries: 8, cache: 25, discount: 75 },
    rag: { requests: 1200, inputTokens: 6500, outputTokens: 900, retries: 5, cache: 45, discount: 75 },
    support: { requests: 3500, inputTokens: 1800, outputTokens: 450, retries: 3, cache: 35, discount: 75 },
    batch: { requests: 50000, inputTokens: 900, outputTokens: 120, retries: 2, cache: 10, discount: 50 },
    custom: null,
  };
  const ids = ['requests','inputTokens','outputTokens','retries','cache','discount'];
  function money(n){ return n < 100 ? `$${n.toFixed(2)}` : `$${Math.round(n).toLocaleString()}`; }
  function num(n){ return Math.round(n).toLocaleString(); }
  function params(){ const o={}; ids.forEach(id=>o[id]=Number(document.getElementById(id).value||0)); return o; }
  function applyPreset(name){ const p=presets[name]; if(!p) return; ids.forEach(id=>document.getElementById(id).value=p[id]); }
  function calc(){
    const p=params(); const retryMult = 1 + p.retries/100; const monthlyReq = p.requests*30;
    const rawInput = monthlyReq*p.inputTokens*retryMult; const rawOutput = monthlyReq*p.outputTokens*retryMult;
    const paidInput = rawInput * (1 - (p.cache/100)*(p.discount/100));
    document.getElementById('monthly-requests').textContent = `${num(monthlyReq)} requests/mo`;
    document.getElementById('monthly-input').textContent = `${(rawInput/1e6).toFixed(1)}M`;
    document.getElementById('monthly-output').textContent = `${(rawOutput/1e6).toFixed(1)}M`;
    document.getElementById('retry-multiplier').textContent = `${retryMult.toFixed(2)}x`;
    const rows = models.map(m=>({ ...m, cost: (paidInput/1e6)*m.inputCost + (rawOutput/1e6)*m.outputCost })).sort((a,b)=>a.cost-b.cost).slice(0,30);
    const tbody = document.getElementById('results');
    tbody.replaceChildren();
    rows.forEach((m, i) => {
      const tr = document.createElement('tr');
      const cells = [
        `${i + 1}. ${m.model}\n${m.notes || ''}`,
        m.provider,
        `$${m.inputCost}/M`,
        `$${m.outputCost}/M`,
        money(m.cost),
        `${m.lastVerified}`,
      ];
      cells.forEach((value, cellIndex) => {
        const td = document.createElement('td');
        if (cellIndex === 0 || cellIndex === 4) {
          const strong = document.createElement('strong');
          strong.textContent = value.split('\n')[0];
          td.appendChild(strong);
          if (cellIndex === 0 && value.includes('\n')) {
            td.appendChild(document.createElement('br'));
            const span = document.createElement('span');
            span.textContent = value.split('\n').slice(1).join('\n');
            td.appendChild(span);
          }
        } else if (cellIndex === 5) {
          const link = document.createElement('a');
          link.href = m.sourceUrl;
          link.target = '_blank';
          link.rel = 'noopener';
          link.textContent = 'source';
          const small = document.createElement('small');
          small.textContent = value;
          td.appendChild(link);
          td.appendChild(document.createElement('br'));
          td.appendChild(small);
        } else {
          td.textContent = value;
        }
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });
    const q = new URLSearchParams({ preset: document.getElementById('preset').value, ...p }); history.replaceState(null,'',`${location.pathname}?${q}`);
  }
  function load(){ const q=new URLSearchParams(location.search); const preset=q.get('preset')||'coding'; document.getElementById('preset').value=preset; applyPreset(preset); ids.forEach(id=>{ if(q.has(id)) document.getElementById(id).value=q.get(id); }); calc(); }
  document.getElementById('preset').addEventListener('change',e=>{ applyPreset(e.target.value); calc(); });
  ids.forEach(id=>document.getElementById(id).addEventListener('input',()=>{ document.getElementById('preset').value='custom'; calc(); }));
  document.getElementById('calculate').addEventListener('click', calc);
  document.getElementById('copy-url').addEventListener('click', async()=>{ try{ await navigator.clipboard.writeText(location.href); document.getElementById('copy-url').textContent='Copied'; }catch{} });
  load();
</script>
</body></html>
<style>
.page{padding-bottom:4rem}.container{max-width:1120px;margin:0 auto;padding:0 1.5rem}.hero{padding:4rem 0 2.5rem;background:var(--gradient-hero)}.eyebrow{color:var(--accent-light);text-transform:uppercase;letter-spacing:.08em;font-size:.78rem;font-weight:800}h1{font-size:clamp(2.3rem,5vw,4rem);margin:.4rem 0 1rem}.subtitle{color:var(--text-secondary);max-width:780px;font-size:1.08rem;line-height:1.7}.hero-actions{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.2rem}.btn,button{display:inline-flex;justify-content:center;padding:.85rem 1rem;border-radius:12px;border:0;font-weight:800;text-decoration:none;cursor:pointer}.primary,button{background:var(--gradient-primary);color:#fff}.secondary,.secondary-button{background:var(--bg-tertiary);color:var(--text-primary);border:1px solid var(--border-primary)}.calc-grid{display:grid;grid-template-columns:minmax(0,1fr)380px;gap:1rem;padding-top:2rem}.panel{background:var(--bg-card);border:1px solid var(--border-primary);border-radius:18px;padding:1.25rem}label{display:grid;gap:.4rem;color:var(--text-secondary);font-weight:700;margin-top:1rem}input,select{background:var(--bg-secondary);color:var(--text-primary);border:1px solid var(--border-primary);border-radius:12px;padding:.8rem}.two{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}.metric{display:flex;justify-content:space-between;border-bottom:1px solid var(--border-secondary);padding:.8rem 0}.metric span,.muted,td span,small{color:var(--text-tertiary)}.section{padding-top:2rem}.table-wrap{overflow-x:auto;background:var(--bg-card);border:1px solid var(--border-primary);border-radius:18px}table{width:100%;border-collapse:collapse}th,td{padding:.9rem 1rem;border-bottom:1px solid var(--border-secondary);text-align:left}th{color:var(--text-secondary)}a{color:var(--accent-light);font-weight:700}@media(max-width:900px){.calc-grid{grid-template-columns:1fr}.two{grid-template-columns:1fr}}
</style>
