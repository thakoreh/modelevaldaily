---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'AI Model Cost Calculator | Compare API Pricing Across Providers';
const description = 'Interactive cost calculator for AI APIs. Compare OpenAI GPT-5, Claude, Gemini, and Zhipu GLM pricing. Calculate monthly costs based on your token usage.';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} type="website" />
	</head>
	<body>
		<Header />
		<main>
			<div class="container">
				<div class="hero">
					<h1>AI Model Cost Calculator</h1>
					<p class="subtitle">Compare API pricing across OpenAI, Anthropic, Google, and Zhipu</p>
					<p class="verified-date">Pricing verified: March 10, 2026 • Check official sources for current rates</p>
				</div>

				<div class="calculator-section">
					<div class="input-panel">
						<h2>Estimate Your Costs</h2>
						<div class="input-group">
							<label for="tokens-per-month">Tokens per Month (millions)</label>
							<input type="number" id="tokens-per-month" value="10" min="0.1" max="10000" step="0.1" />
							<span class="hint">1M tokens ≈ 750K words (English)</span>
						</div>
						<div class="input-group">
							<label for="input-ratio">Input/Output Ratio</label>
							<select id="input-ratio">
								<option value="0.3">30% input / 70% output (creative)</option>
								<option value="0.5" selected>50% input / 50% output (balanced)</option>
								<option value="0.7">70% input / 30% output (analysis)</option>
								<option value="0.9">90% input / 10% output (extraction)</option>
							</select>
						</div>
						<div class="results-summary">
							<div class="summary-item">
								<span class="label">Input tokens:</span>
								<span class="value" id="input-tokens">5M</span>
							</div>
							<div class="summary-item">
								<span class="label">Output tokens:</span>
								<span class="value" id="output-tokens">5M</span>
							</div>
						</div>
					</div>
				</div>

				<div class="pricing-tables">
					<!-- OpenAI -->
					<section class="provider-section">
						<div class="provider-header">
							<h2>OpenAI</h2>
							<a href="https://openai.com/api/pricing/" target="_blank" rel="noopener" class="source-link">Official Pricing →</a>
						</div>
						<div class="table-wrapper">
							<table class="pricing-table" id="openai-table">
								<thead>
									<tr>
										<th>Model</th>
										<th>Input<br/>(per 1M)</th>
										<th>Output<br/>(per 1M)</th>
										<th>Monthly Cost</th>
									</tr>
								</thead>
								<tbody>
									<tr data-input="2.50" data-output="15.00">
										<td><strong>GPT-5.4</strong></td>
										<td>$2.50</td>
										<td>$15.00</td>
										<td class="cost">$87.50</td>
									</tr>
									<tr data-input="0.25" data-output="2.00">
										<td><strong>GPT-5 mini</strong></td>
										<td>$0.25</td>
										<td>$2.00</td>
										<td class="cost">$11.25</td>
									</tr>
									<tr data-input="3.00" data-output="12.00">
										<td>GPT-4.1 (fine-tune)</td>
										<td>$3.00</td>
										<td>$12.00</td>
										<td class="cost">$75.00</td>
									</tr>
									<tr data-input="0.80" data-output="3.20">
										<td>GPT-4.1 mini (fine-tune)</td>
										<td>$0.80</td>
										<td>$3.20</td>
										<td class="cost">$20.00</td>
									</tr>
									<tr data-input="0.20" data-output="0.80">
										<td>GPT-4.1 nano (fine-tune)</td>
										<td>$0.20</td>
										<td>$0.80</td>
										<td class="cost">$5.00</td>
									</tr>
									<tr data-input="4.00" data-output="16.00">
										<td>o4-mini (reasoning)</td>
										<td>$4.00</td>
										<td>$16.00</td>
										<td class="cost">$100.00</td>
									</tr>
								</tbody>
							</table>
						</div>
						<p class="provider-note">Batch API: 50% discount • Cached input: 90% discount</p>
					</section>

					<!-- Anthropic -->
					<section class="provider-section">
						<div class="provider-header">
							<h2>Anthropic Claude</h2>
							<a href="https://docs.anthropic.com/en/docs/about-claude/pricing" target="_blank" rel="noopener" class="source-link">Official Pricing →</a>
						</div>
						<div class="table-wrapper">
							<table class="pricing-table" id="anthropic-table">
								<thead>
									<tr>
										<th>Model</th>
										<th>Input<br/>(per 1M)</th>
										<th>Output<br/>(per 1M)</th>
										<th>Monthly Cost</th>
									</tr>
								</thead>
								<tbody>
									<tr data-input="15.00" data-output="75.00">
										<td><strong>Claude Opus 4.1</strong></td>
										<td>$15.00</td>
										<td>$75.00</td>
										<td class="cost">$450.00</td>
									</tr>
									<tr data-input="5.00" data-output="25.00">
										<td><strong>Claude Opus 4.6</strong></td>
										<td>$5.00</td>
										<td>$25.00</td>
										<td class="cost">$150.00</td>
									</tr>
									<tr data-input="3.00" data-output="15.00">
										<td><strong>Claude Sonnet 4.6</strong></td>
										<td>$3.00</td>
										<td>$15.00</td>
										<td class="cost">$90.00</td>
									</tr>
									<tr data-input="1.00" data-output="5.00">
										<td>Claude Haiku 4.5</td>
										<td>$1.00</td>
										<td>$5.00</td>
										<td class="cost">$30.00</td>
									</tr>
									<tr data-input="0.80" data-output="4.00">
										<td>Claude Haiku 3.5</td>
										<td>$0.80</td>
										<td>$4.00</td>
										<td class="cost">$24.00</td>
									</tr>
									<tr data-input="0.25" data-output="1.25">
										<td>Claude Haiku 3</td>
										<td>$0.25</td>
										<td>$1.25</td>
										<td class="cost">$7.50</td>
									</tr>
								</tbody>
							</table>
						</div>
						<p class="provider-note">Batch API: 50% discount • Prompt caching: 75% discount (1h cache)</p>
					</section>

					<!-- Google Gemini -->
					<section class="provider-section">
						<div class="provider-header">
							<h2>Google Gemini</h2>
							<a href="https://ai.google.dev/gemini-api/docs/pricing" target="_blank" rel="noopener" class="source-link">Official Pricing →</a>
						</div>
						<div class="table-wrapper">
							<table class="pricing-table" id="gemini-table">
								<thead>
									<tr>
										<th>Model</th>
										<th>Input<br/>(per 1M)</th>
										<th>Output<br/>(per 1M)</th>
										<th>Monthly Cost</th>
									</tr>
								</thead>
								<tbody>
									<tr data-input="2.00" data-output="12.00">
										<td><strong>Gemini 3 Pro Preview</strong></td>
										<td>$2.00</td>
										<td>$12.00</td>
										<td class="cost">$70.00</td>
									</tr>
									<tr data-input="1.25" data-output="10.00">
										<td><strong>Gemini 2.5 Pro</strong></td>
										<td>$1.25</td>
										<td>$10.00</td>
										<td class="cost">$56.25</td>
									</tr>
									<tr data-input="0.15" data-output="0.60">
										<td>Gemini 2.5 Flash</td>
										<td>$0.15</td>
										<td>$0.60</td>
										<td class="cost">$3.75</td>
									</tr>
									<tr data-input="0.15" data-output="3.50">
										<td>Gemini 2.5 Flash (Thinking)</td>
										<td>$0.15</td>
										<td>$3.50</td>
										<td class="cost">$18.25</td>
									</tr>
									<tr data-input="0.10" data-output="0.40">
										<td>Gemini 2.5 Flash-Lite</td>
										<td>$0.10</td>
										<td>$0.40</td>
										<td class="cost">$2.50</td>
									</tr>
									<tr data-input="0.10" data-output="0.40">
										<td>Gemini 2.0 Flash</td>
										<td>$0.10</td>
										<td>$0.40</td>
										<td class="cost">$2.50</td>
									</tr>
								</tbody>
							</table>
						</div>
						<p class="provider-note">Free tier: 15-1,000 req/day • Batch API: 50% discount • Context >200K: 2x price</p>
					</section>

					<!-- Zhipu -->
					<section class="provider-section">
						<div class="provider-header">
							<h2>Zhipu AI (GLM)</h2>
							<a href="https://open.bigmodel.cn/pricing" target="_blank" rel="noopener" class="source-link">Official Pricing →</a>
						</div>
						<div class="table-wrapper">
							<table class="pricing-table" id="zhipu-table">
								<thead>
									<tr>
										<th>Model</th>
										<th>Input<br/>(per 1M)</th>
										<th>Output<br/>(per 1M)</th>
										<th>Monthly Cost</th>
									</tr>
								</thead>
								<tbody>
									<tr data-input="1.00" data-output="3.20">
										<td><strong>GLM-5</strong> (744B params)</td>
										<td>$1.00</td>
										<td>$3.20</td>
										<td class="cost">$21.00</td>
									</tr>
									<tr data-input="0.50" data-output="2.20">
										<td>GLM-4.7</td>
										<td>$0.50</td>
										<td>$2.20</td>
										<td class="cost">$13.50</td>
									</tr>
									<tr data-input="0.00" data-output="0.00" class="free-tier">
										<td>GLM-4.7-Flash</td>
										<td>$0.00</td>
										<td>$0.00</td>
										<td class="cost">Free tier</td>
									</tr>
									<tr data-input="0.00" data-output="0.00" class="free-tier">
										<td>GLM-4.5-Flash</td>
										<td>$0.00</td>
										<td>$0.00</td>
										<td class="cost">Free tier</td>
									</tr>
									<tr data-input="1.00" data-output="8.90">
										<td>GLM-4.5-X</td>
										<td>$1.00</td>
										<td>$8.90</td>
										<td class="cost">$49.50</td>
									</tr>
								</tbody>
							</table>
						</div>
						<p class="provider-note">GLM-5 Coding Plan: $3/mo (new user promo removed Feb 2026) • Free Flash tiers available</p>
					</section>
				</div>

				<div class="comparison-section">
					<h2>Quick Comparison: Best Value by Tier</h2>
					<div class="comparison-grid">
						<div class="tier-card budget">
							<h3>Budget Tier</h3>
							<div class="winner">
								<span class="model">Gemini Flash-Lite</span>
								<span class="price">$0.10 / $0.40</span>
							</div>
							<ul>
								<li>GLM-4.5-Flash: <strong>Free</strong></li>
								<li>Gemini 2.0 Flash: $0.10 / $0.40</li>
								<li>GPT-4.1 nano: $0.20 / $0.80</li>
								<li>Claude Haiku 3: $0.25 / $1.25</li>
							</ul>
						</div>
						<div class="tier-card balanced">
							<h3>Balanced Tier</h3>
							<div class="winner">
								<span class="model">Gemini 2.5 Flash</span>
								<span class="price">$0.15 / $0.60</span>
							</div>
							<ul>
								<li>GPT-5 mini: $0.25 / $2.00</li>
								<li>Claude Haiku 4.5: $1.00 / $5.00</li>
								<li>GLM-5: $1.00 / $3.20</li>
							</ul>
						</div>
						<div class="tier-card premium">
							<h3>Premium Tier</h3>
							<div class="winner">
								<span class="model">Gemini 2.5 Pro</span>
								<span class="price">$1.25 / $10.00</span>
							</div>
							<ul>
								<li>Gemini 3 Pro: $2.00 / $12.00</li>
								<li>GPT-5.4: $2.50 / $15.00</li>
								<li>Claude Sonnet 4.6: $3.00 / $15.00</li>
							</ul>
						</div>
						<div class="tier-card flagship">
							<h3>Flagship Tier</h3>
							<div class="winner">
								<span class="model">Claude Opus 4.6</span>
								<span class="price">$5.00 / $25.00</span>
							</div>
							<ul>
								<li>Claude Opus 4.1: $15.00 / $75.00</li>
								<li>o4-mini (reasoning): $4.00 / $16.00</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="disclaimer">
					<h3>Important Disclaimers</h3>
					<ul>
						<li><strong>Pricing verified March 10, 2026.</strong> AI model pricing changes frequently. Always check official sources before making decisions.</li>
						<li>Prices shown are standard API rates. Volume discounts, batch processing, and caching can reduce costs significantly.</li>
						<li>Input/output ratios affect real costs. Output tokens typically cost 3-5x more than input tokens.</li>
						<li>Context window length may affect pricing (e.g., Gemini >200K tokens = 2x price).</li>
						<li>Free tiers have rate limits (requests per minute/day) that may not suit production use.</li>
						<li>Regional endpoints (data residency) may add 10% premium on some providers.</li>
					</ul>
				</div>

				<div class="resources">
					<h2>Official Pricing Pages</h2>
					<div class="resource-links">
						<a href="https://openai.com/api/pricing/" target="_blank" rel="noopener" class="resource-link">
							<span class="provider-name">OpenAI</span>
							<span class="url">openai.com/api/pricing</span>
						</a>
						<a href="https://docs.anthropic.com/en/docs/about-claude/pricing" target="_blank" rel="noopener" class="resource-link">
							<span class="provider-name">Anthropic Claude</span>
							<span class="url">docs.anthropic.com/pricing</span>
						</a>
						<a href="https://ai.google.dev/gemini-api/docs/pricing" target="_blank" rel="noopener" class="resource-link">
							<span class="provider-name">Google Gemini</span>
							<span class="url">ai.google.dev/pricing</span>
						</a>
						<a href="https://open.bigmodel.cn/pricing" target="_blank" rel="noopener" class="resource-link">
							<span class="provider-name">Zhipu AI</span>
							<span class="url">open.bigmodel.cn/pricing</span>
						</a>
					</div>
				</div>
			</div>
		</main>
		<Footer />

		<script>
			const tokensInput = document.getElementById('tokens-per-month') as HTMLInputElement;
			const ratioSelect = document.getElementById('input-ratio') as HTMLSelectElement;
			const inputTokensDisplay = document.getElementById('input-tokens') as HTMLElement;
			const outputTokensDisplay = document.getElementById('output-tokens') as HTMLElement;

			function formatCurrency(value: number): string {
				if (value < 0.01) return '<$0.01';
				if (value < 1) return '$' + value.toFixed(2);
				if (value >= 1000) return '$' + value.toLocaleString('en-US', { maximumFractionDigits: 0 });
				return '$' + value.toFixed(2);
			}

			function calculateCosts() {
				const totalTokens = parseFloat(tokensInput.value) || 0;
				const inputRatio = parseFloat(ratioSelect.value);
				const outputRatio = 1 - inputRatio;

				const inputTokens = totalTokens * inputRatio;
				const outputTokens = totalTokens * outputRatio;

				inputTokensDisplay.textContent = inputTokens.toFixed(1) + 'M';
				outputTokensDisplay.textContent = outputTokens.toFixed(1) + 'M';

				// Update all pricing tables
				document.querySelectorAll('.pricing-table tbody tr').forEach(row => {
					const inputPrice = parseFloat(row.getAttribute('data-input') || '0');
					const outputPrice = parseFloat(row.getAttribute('data-output') || '0');
					const costCell = row.querySelector('.cost') as HTMLElement;

					if (row.classList.contains('free-tier')) {
						costCell.textContent = 'Free tier';
						return;
					}

					const cost = (inputTokens * inputPrice) + (outputTokens * outputPrice);
					costCell.textContent = formatCurrency(cost);
				});
			}

			tokensInput.addEventListener('input', calculateCosts);
			ratioSelect.addEventListener('change', calculateCosts);

			// Initial calculation
			calculateCosts();
		</script>
	</body>
</html>

<style>
	main {
		min-height: 100vh;
		padding: 2rem 1.5rem 4rem;
	}

	.container {
		max-width: var(--container-xl);
		margin: 0 auto;
	}

	.hero {
		text-align: center;
		margin-bottom: 3rem;
		padding-top: 1rem;
	}

	h1 {
		font-size: clamp(2rem, 4vw, 3rem);
		margin: 0 0 0.75rem;
		background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent-light) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.subtitle {
		font-size: var(--font-lg);
		color: var(--text-secondary);
		margin: 0 0 1rem;
	}

	.verified-date {
		font-size: var(--font-sm);
		color: var(--text-tertiary);
		padding: 0.5rem 1rem;
		background: rgba(245, 158, 11, 0.1);
		border: 1px solid rgba(245, 158, 11, 0.3);
		border-radius: var(--radius-full);
		display: inline-block;
	}

	.calculator-section {
		background: var(--bg-secondary);
		border: 1px solid var(--border-primary);
		border-radius: var(--radius-lg);
		padding: 2rem;
		margin-bottom: 3rem;
	}

	.input-panel h2 {
		margin: 0 0 1.5rem;
		font-size: var(--font-xl);
	}

	.input-group {
		margin-bottom: 1.5rem;
	}

	.input-group label {
		display: block;
		font-size: var(--font-sm);
		font-weight: 600;
		color: var(--text-secondary);
		margin-bottom: 0.5rem;
	}

	.input-group input,
	.input-group select {
		width: 100%;
		max-width: 300px;
		padding: 0.75rem 1rem;
		font-size: var(--font-base);
		background: var(--bg-tertiary);
		border: 1px solid var(--border-primary);
		border-radius: var(--radius-md);
		color: var(--text-primary);
	}

	.input-group input:focus,
	.input-group select:focus {
		outline: none;
		border-color: var(--accent-light);
		box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
	}

	.hint {
		display: block;
		font-size: var(--font-xs);
		color: var(--text-tertiary);
		margin-top: 0.5rem;
	}

	.results-summary {
		display: flex;
		gap: 2rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border-secondary);
	}

	.summary-item {
		display: flex;
		gap: 0.5rem;
		align-items: baseline;
	}

	.summary-item .label {
		color: var(--text-tertiary);
		font-size: var(--font-sm);
	}

	.summary-item .value {
		font-weight: 700;
		color: var(--text-primary);
	}

	.pricing-tables {
		display: grid;
		gap: 2rem;
		margin-bottom: 3rem;
	}

	.provider-section {
		background: var(--bg-secondary);
		border: 1px solid var(--border-primary);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.provider-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 1.5rem;
		background: var(--bg-tertiary);
		border-bottom: 1px solid var(--border-primary);
	}

	.provider-header h2 {
		margin: 0;
		font-size: var(--font-lg);
	}

	.source-link {
		font-size: var(--font-sm);
		color: var(--accent-light);
		text-decoration: none;
	}

	.source-link:hover {
		text-decoration: underline;
	}

	.table-wrapper {
		overflow-x: auto;
	}

	.pricing-table {
		width: 100%;
		border-collapse: collapse;
	}

	.pricing-table th,
	.pricing-table td {
		padding: 0.75rem 1rem;
		text-align: left;
		border-bottom: 1px solid var(--border-secondary);
	}

	.pricing-table th {
		font-size: var(--font-xs);
		font-weight: 600;
		color: var(--text-tertiary);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: rgba(0, 0, 0, 0.2);
	}

	.pricing-table td {
		font-size: var(--font-sm);
		color: var(--text-secondary);
	}

	.pricing-table tr:hover td {
		background: var(--bg-tertiary);
	}

	.pricing-table td strong {
		color: var(--text-primary);
	}

	.pricing-table .cost {
		font-weight: 700;
		color: var(--success);
	}

	.pricing-table .free-tier .cost {
		color: var(--accent-light);
	}

	.provider-note {
		font-size: var(--font-xs);
		color: var(--text-tertiary);
		padding: 0.75rem 1.5rem;
		margin: 0;
		background: var(--bg-tertiary);
		border-top: 1px solid var(--border-secondary);
	}

	.comparison-section {
		margin-bottom: 3rem;
	}

	.comparison-section h2 {
		margin: 0 0 1.5rem;
		font-size: var(--font-xl);
	}

