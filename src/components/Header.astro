---
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<div class="nav-shell">
		<a href="/" class="brand" aria-label="AI Model Benchmarks home">
			<span class="brand-mark" aria-hidden="true">AM</span>
			<span class="brand-copy"><strong>AI Model</strong><span>Benchmarks</span></span>
		</a>
		<nav class="desktop-nav" aria-label="Primary navigation">
			<HeaderLink href="/models/">Rankings</HeaderLink>
			<HeaderLink href="/compare/">Compare</HeaderLink>
			<HeaderLink href="/use-cases/">Use cases</HeaderLink>
			<HeaderLink href="/blog/">Research</HeaderLink>
			<HeaderLink href="/model-data/">Methodology</HeaderLink>
		</nav>
		<div class="nav-actions">
			<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Switch color theme" title="Switch color theme">
				<svg class="sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3.5"/><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42"/></svg>
				<svg class="moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.2 15.2A8.4 8.4 0 0 1 8.8 3.8 8.5 8.5 0 1 0 20.2 15.2Z"/></svg>
			</button>
			<a class="find-model" href="/tools/model-picker/">Find a model <span aria-hidden="true">→</span></a>
			<button class="menu-toggle" id="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open navigation">
				<span></span><span></span><span></span>
			</button>
		</div>
	</div>
	<nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation">
		<a href="/models/">Rankings</a><a href="/compare/">Compare</a><a href="/use-cases/">Use cases</a><a href="/blog/">Research</a><a href="/model-data/">Methodology</a><a href="/tools/model-picker/">Find a model →</a>
	</nav>
</header>

<script is:inline>
	(() => {
		const root = document.documentElement;
		const themeButton = document.getElementById('theme-toggle');
		const menuButton = document.getElementById('menu-toggle');
		const menu = document.getElementById('mobile-menu');
		const updateThemeLabel = () => {
			const dark = root.dataset.theme === 'dark';
			themeButton?.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
		};
		updateThemeLabel();
		themeButton?.addEventListener('click', () => {
			const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
			root.dataset.theme = next;
			localStorage.setItem('amb-theme', next);
			updateThemeLabel();
			window.dispatchEvent(new CustomEvent('amb:theme-change', { detail: { theme: next } }));
		});
		const closeMenu = () => {
			menu?.classList.remove('open');
			menuButton?.setAttribute('aria-expanded', 'false');
		};
		menuButton?.addEventListener('click', () => {
			const open = menu?.classList.toggle('open') ?? false;
			menuButton.setAttribute('aria-expanded', String(open));
		});
		menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
		document.addEventListener('keydown', (event) => event.key === 'Escape' && closeMenu());
	})();
</script>

<style>
	.site-header { position: sticky; top: 0; z-index: 100; border-bottom: 1px solid var(--line); background: color-mix(in srgb, var(--canvas) 92%, transparent); backdrop-filter: blur(16px); }
	.nav-shell { width: min(var(--container-xl), calc(100% - 3rem)); min-height: 68px; margin: 0 auto; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 1.5rem; }
	.brand { width: fit-content; display: inline-flex; align-items: center; gap: 0.65rem; color: var(--ink); text-decoration: none; }
	.brand-mark { display: grid; width: 34px; height: 34px; place-items: center; border: 1px solid var(--ink); border-radius: 50%; font: 700 0.68rem var(--font-mono); letter-spacing: -0.05em; }
	.brand-copy { display: flex; flex-direction: column; line-height: 0.95; font-size: 0.82rem; }
	.brand-copy strong { font-weight: 720; }
	.brand-copy span { color: var(--ink-muted); }
	.desktop-nav { display: flex; align-items: center; gap: 1.35rem; }
	.desktop-nav :global(a) { position: relative; color: var(--ink-muted); font-size: 0.86rem; font-weight: 620; text-decoration: none; }
	.desktop-nav :global(a:hover), .desktop-nav :global(a.active) { color: var(--ink); }
	.desktop-nav :global(a.active)::after { content: ''; position: absolute; left: 0; right: 0; bottom: -0.55rem; height: 2px; background: var(--blue); }
	.nav-actions { justify-self: end; display: flex; align-items: center; gap: 0.6rem; }
	.theme-toggle { display: grid; width: 40px; height: 40px; place-items: center; padding: 0; border: 1px solid var(--line); border-radius: 50%; background: var(--surface); color: var(--ink); cursor: pointer; }
	.theme-toggle svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
	.theme-toggle .moon, :global([data-theme='dark']) .theme-toggle .sun { display: none; }
	:global([data-theme='dark']) .theme-toggle .moon { display: block; }
	.find-model { display: inline-flex; align-items: center; gap: 0.4rem; min-height: 40px; padding: 0.55rem 0.85rem; border-radius: var(--radius-md); background: var(--blue); color: #fff; font-size: 0.84rem; font-weight: 680; text-decoration: none; }
	.find-model:hover { background: var(--blue-dark); color: #fff; }
	.menu-toggle { display: none; width: 40px; height: 40px; padding: 10px; border: 1px solid var(--line); border-radius: 50%; background: var(--surface); }
	.menu-toggle span { display: block; height: 1px; margin: 4px 0; background: var(--ink); }
	.mobile-menu { display: none; }
	@media (max-width: 900px) {
		.nav-shell { width: calc(100% - 1.25rem); grid-template-columns: 1fr auto; }
		.desktop-nav, .find-model { display: none; }
		.menu-toggle { display: block; }
		.mobile-menu.open { display: grid; padding: 0.4rem 1rem 1rem; border-top: 1px solid var(--line); background: var(--canvas); }
		.mobile-menu a { padding: 0.7rem 0; border-bottom: 1px solid var(--line); color: var(--ink); font-weight: 620; text-decoration: none; }
	}
</style>
