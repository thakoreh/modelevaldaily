---
import type { HTMLAttributes } from 'astro/types';
type Props = HTMLAttributes<'a'>;
const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const root = '/' + (pathname.match(/[^/]+/g)?.[0] || '');
const normalize = (value: string) => value.replace(/\/+$/, '') || '/';
const isActive = normalize(String(href)) === normalize(pathname) || normalize(String(href)) === root;
---
<a href={href} class:list={[className, { active: isActive }]} aria-current={isActive ? 'page' : undefined} {...props}><slot /></a>
