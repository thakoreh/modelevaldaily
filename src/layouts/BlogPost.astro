---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];
const {
	title,
	description,
	pubDate,
	updatedDate,
	category = 'Research',
	author = 'AI Model Benchmarks',
	reviewedBy,
	verdict,
	sourceCount,
	relatedTools = [
		{ label: 'Compare models', href: '/compare/' },
		{ label: 'Open rankings', href: '/models/' },
		{ label: 'Inspect source data', href: '/model-data/' },
	],
	noindex = false,
} = Astro.props;
const titleWithSite = title.includes('AI Model Benchmarks') ? title : `${title} | AI Model Benchmarks`;
const pageTitle = titleWithSite.length <= 65 ? titleWithSite : title.length <= 65 ? title : `${title.slice(0, 62).trim()}...`;
const content = await Astro.slots.render('default');
const wordCount = content.replace(/<[^>]+>/g, ' ').trim().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 220));
---
<html lang="en">
	<head><BaseHead title={pageTitle} description={description} type="article" publishDate={pubDate} modifiedDate={updatedDate} noindex={noindex} /></head>
	<body>
		<Header />
		<main class="article-page">
			<header class="article-header container">
				<a class="back-link" href="/blog/">← All research</a>
				<div class="article-heading">
					<div><span class="eyebrow">{category}</span><h1>{title}</h1><p class="dek">{description}</p></div>
					<dl class="article-facts">
						<div><dt>Published</dt><dd><FormattedDate date={pubDate} /></dd></div>
						{updatedDate && <div><dt>Updated</dt><dd><FormattedDate date={updatedDate} /></dd></div>}
						<div><dt>By</dt><dd>{author}</dd></div>
						{reviewedBy && <div><dt>Reviewed by</dt><dd>{reviewedBy}</dd></div>}
						<div><dt>Reading time</dt><dd>{readingTime} min</dd></div>
						{typeof sourceCount === 'number' && <div><dt>Sources</dt><dd>{sourceCount}</dd></div>}
					</dl>
				</div>
			</header>

			<div class="article-shell container">
				<aside class="article-rail">
					<div class="rail-card"><span>On this page</span><nav id="article-toc" aria-label="Article contents"></nav></div>
					<div class="rail-card evidence-card"><span>Evidence note</span><p>Provider details and prices can change. Check linked sources and the article’s review date before making a production decision.</p><a href="/model-data/">Review policy →</a></div>
				</aside>
				<article class="article-content">
					<div class="takeaway"><span>Bottom line</span><p>{verdict ?? description}</p></div>
					<div class="prose" id="article-body"><Fragment set:html={content} /></div>
					<footer class="article-next"><span class="eyebrow">Continue the decision</span><div>{relatedTools.map((tool) => <a href={tool.href}>{tool.label} <span aria-hidden="true">→</span></a>)}</div></footer>
				</article>
			</div>
		</main>
		<Footer />
		<script is:inline>
			(() => {
				const body = document.getElementById('article-body');
				const toc = document.getElementById('article-toc');
				if (!body || !toc) return;
				const headings = [...body.querySelectorAll('h2, h3')];
				headings.forEach((heading, index) => {
					if (!heading.id) heading.id = `section-${index + 1}`;
					const link = document.createElement('a');
					link.href = `#${heading.id}`;
					link.textContent = heading.textContent;
					if (heading.tagName === 'H3') link.className = 'toc-sub';
					toc.append(link);
				});
				if (headings.length === 0) toc.closest('.rail-card')?.remove();
			})();
		</script>
	</body>
</html>

<style>
	.article-page { width: 100%; max-width: none; padding: 0; }
	.article-header { padding-block: 3rem 4rem; border-bottom: 1px solid var(--line); }
	.back-link { display: inline-block; margin-bottom: 4rem; color: var(--ink-muted); font-size: 0.82rem; text-decoration: none; }
	.article-heading { display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(250px, 0.65fr); gap: clamp(3rem, 8vw, 8rem); align-items: end; }
	.article-heading h1 { max-width: 900px; font-size: clamp(3.2rem, 6vw, 6.2rem); line-height: 0.96; }
	.dek { max-width: 760px; margin-top: 1.5rem; font: 1.2rem/1.55 var(--font-serif); }
	.article-facts { margin: 0; border-top: 1px solid var(--line-strong); }
	.article-facts div { display: grid; grid-template-columns: 1fr 1.5fr; gap: 1rem; padding: 0.55rem 0; border-bottom: 1px solid var(--line); }
	.article-facts dt { color: var(--ink-faint); font-size: 0.72rem; text-transform: uppercase; }
	.article-facts dd { margin: 0; color: var(--ink); font-size: 0.8rem; }
	.article-shell { padding-block: 4rem; display: grid; grid-template-columns: 240px minmax(0, 760px); gap: clamp(3rem, 8vw, 7rem); justify-content: center; }
	.article-rail { position: sticky; top: 6rem; align-self: start; display: flex; flex-direction: column; gap: 1rem; }
	.rail-card { padding-top: 0.8rem; border-top: 1px solid var(--line-strong); }
	.rail-card > span, .takeaway > span { color: var(--ink); font-size: 0.7rem; font-weight: 720; letter-spacing: 0.08em; text-transform: uppercase; }
	.rail-card nav { margin-top: 0.7rem; display: flex; flex-direction: column; gap: 0.4rem; }
	.rail-card :global(a) { color: var(--ink-muted); font-size: 0.78rem; text-decoration: none; }
	.rail-card :global(a.toc-sub) { padding-left: 0.75rem; color: var(--ink-faint); }
	.evidence-card { margin-top: 1rem; padding: 1rem; border: 1px solid var(--line); background: var(--surface); }
	.evidence-card p { margin: 0.5rem 0; font-size: 0.76rem; }
	.evidence-card a { font-size: 0.76rem; }
	.takeaway { margin-bottom: 3rem; padding: 1.4rem 1.5rem; border-left: 4px solid var(--blue); background: var(--blue-soft); }
	.takeaway p { margin: 0.5rem 0 0; color: var(--ink); font: 1.16rem/1.55 var(--font-serif); }
	.article-content .prose { max-width: 760px; }
	.article-next { margin-top: 5rem; padding-top: 2rem; border-top: 1px solid var(--line-strong); }
	.article-next > div { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
	.article-next a { min-height: 100px; padding: 1rem; border: 1px solid var(--line); display: flex; align-items: flex-end; justify-content: space-between; color: var(--ink); font-size: 0.86rem; font-weight: 650; text-decoration: none; background: var(--surface); }
	.article-next a:hover { background: var(--blue-soft); }
	@media (max-width: 850px) { .article-heading { grid-template-columns: 1fr; } .article-shell { grid-template-columns: 1fr; } .article-rail { position: static; } .evidence-card { display: none; } .article-next > div { grid-template-columns: 1fr; } }
	@media (max-width: 600px) { .article-header { padding-block: 2rem 3rem; } .back-link { margin-bottom: 3rem; } .article-heading h1 { font-size: clamp(3rem, 14vw, 4.3rem); } .dek { font-size: 1.05rem; } .article-shell { padding-block: 2.5rem; } }
</style>
